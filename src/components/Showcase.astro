---
---
<section id="showcase" class="section overflow-hidden">
  <div class="container">
    <div class="showcase__header reveal">
      <span class="label text-primary">Showcase</span>
      <h2 class="heading-xl" style="margin-top: 0.5rem;">
        Invitations That<br/>
        <em class="font-serif">Tell Stories</em>
      </h2>
    </div>

    <div class="showcase__layout" style="margin-top: var(--space-2xl);">
      <!-- Main large card -->
      <div class="showcase__main reveal-scale">
        <div class="showcase__card showcase__card--large tilt-card">
          <div class="showcase__card-bg" style="background: linear-gradient(135deg, #FF5252 0%, #FF8A80 50%, #F9E8D0 100%);">
            <div class="showcase__particles" aria-hidden="true">
              <div class="particle float" style="top: 10%; left: 15%; width: 6px; height: 6px; background: rgba(255,255,255,0.6); border-radius: 50%; animation-delay: 0s;"></div>
              <div class="particle float-reverse" style="top: 30%; right: 20%; width: 4px; height: 4px; background: rgba(255,255,255,0.4); border-radius: 50%; animation-delay: 1s;"></div>
              <div class="particle float-slow" style="top: 60%; left: 40%; width: 8px; height: 8px; background: rgba(255,255,255,0.3); border-radius: 50%; animation-delay: 2s;"></div>
              <div class="particle float" style="top: 80%; right: 30%; width: 5px; height: 5px; background: rgba(255,255,255,0.5); border-radius: 50%; animation-delay: 0.5s;"></div>
            </div>
            <div class="showcase__card-content">
              <span class="showcase__badge">Wedding Invite</span>
              <h3 class="font-serif" style="font-size: clamp(1.8rem, 3vw, 2.8rem); color: white; line-height: 1.2;">
                Arjun<br/>&amp; Priya
              </h3>
              <div class="showcase__divider"></div>
              <p style="color: rgba(255,255,255,0.85); font-size: 0.9rem;">
                Together with their families<br/>
                invite you to celebrate their union
              </p>
              <div class="showcase__date-badge">
                <span style="font-weight: 700; font-size: 1.5rem; font-family: var(--font-heading);">12</span>
                <span style="font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em;">Dec 2026</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Side cards -->
      <div class="showcase__side">
        <div class="showcase__card showcase__card--small card-hover reveal-right" style="transition-delay: 0.1s;">
          <div class="showcase__card-bg" style="background: linear-gradient(135deg, #E8D5F5 0%, #C9B1FF 100%);">
            <div class="showcase__card-content">
              <span class="showcase__badge" style="background: rgba(126,87,194,0.3); color: #311B92;">Birthday</span>
              <h3 class="font-serif" style="font-size: 1.4rem; color: #311B92;">
                Isha turns<br/><span style="font-size: 2.5rem;">25</span>
              </h3>
              <p style="color: #5C6BC0; font-size: 0.85rem;">Let's celebrate!</p>
            </div>
          </div>
        </div>

        <div class="showcase__card showcase__card--small card-hover reveal-right" style="transition-delay: 0.25s;">
          <div class="showcase__card-bg" style="background: linear-gradient(135deg, #F9E8D0 0%, #FFD6A5 100%);">
            <div class="showcase__card-content">
              <span class="showcase__badge" style="background: rgba(212,163,115,0.3); color: #5D4037;">Corporate</span>
              <h3 class="font-serif" style="font-size: 1.4rem; color: #5D4037;">
                Annual<br/>Gala 2026
              </h3>
              <p style="color: #8D6E63; font-size: 0.85rem;">An evening of elegance</p>
            </div>
          </div>
        </div>

        <div class="showcase__card showcase__card--small card-hover reveal-right" style="transition-delay: 0.4s;">
          <div class="showcase__card-bg" style="background: linear-gradient(135deg, #1A1A2E 0%, #16213E 100%);">
            <div class="showcase__card-content">
              <span class="showcase__badge" style="background: rgba(255,82,82,0.3); color: #FF8A80;">Party</span>
              <h3 class="font-serif" style="font-size: 1.4rem; color: white;">
                New Year's<br/>Bash
              </h3>
              <p style="color: rgba(255,255,255,0.6); font-size: 0.85rem;">Ring in 2027!</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .showcase__header {
    max-width: 500px;
  }

  .showcase__layout {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 1.5rem;
    align-items: start;
  }

  .showcase__card {
    border-radius: var(--radius-xl);
    overflow: hidden;
    position: relative;
  }

  .showcase__card-bg {
    width: 100%;
    height: 100%;
    position: relative;
    overflow: hidden;
  }

  .showcase__card--large .showcase__card-bg {
    aspect-ratio: 3 / 4;
  }

  .showcase__card--small .showcase__card-bg {
    aspect-ratio: 4 / 3;
  }

  .showcase__card-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    height: 100%;
    padding: 2rem;
  }

  .showcase__badge {
    display: inline-block;
    background: rgba(255, 255, 255, 0.25);
    color: white;
    padding: 0.25rem 0.75rem;
    border-radius: var(--radius-full);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    width: fit-content;
    margin-bottom: 0.75rem;
  }

  .showcase__divider {
    width: 40px;
    height: 2px;
    background: rgba(255, 255, 255, 0.5);
    margin: 0.75rem 0;
  }

  .showcase__date-badge {
    display: flex;
    flex-direction: column;
    align-items: center;
    background: rgba(255, 255, 255, 0.2);
    backdrop-filter: blur(8px);
    width: 60px;
    padding: 0.5rem;
    border-radius: var(--radius-md);
    color: white;
    text-align: center;
    margin-top: 1rem;
  }

  .showcase__particles {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .showcase__side {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  @media (max-width: 768px) {
    .showcase__layout {
      grid-template-columns: 1fr;
    }

    .showcase__side {
      flex-direction: row;
      overflow-x: auto;
      padding-bottom: 1rem;
    }

    .showcase__card--small {
      min-width: 220px;
    }
  }
</style>

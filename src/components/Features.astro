---
const features = [
  {
    icon: '📤',
    title: 'Upload Any Format',
    description: 'Bring your own invitation — image, video, PDF, or text. Designed on Canva, a phone, or by a professional. Lumhe handles the rest.',
    color: '#FF5252',
    bg: 'rgba(255, 82, 82, 0.06)',
  },
  {
    icon: '🔍',
    title: 'Find & Connect Guests',
    description: 'Discover people by name, phone number, or email. Build your celebration circle — your guest list grows with every event.',
    color: '#8B5CF6',
    bg: 'rgba(139, 92, 246, 0.06)',
  },
  {
    icon: '📋',
    title: 'Per-Function RSVP',
    description: 'Track RSVPs for each function separately — Mehendi, Sangeet, Ceremony, Reception. Know exactly who\'s coming to what.',
    color: '#3B82F6',
    bg: 'rgba(59, 130, 246, 0.06)',
  },
  {
    icon: '📸',
    title: 'Shared Moments',
    description: 'A permanent photo timeline for your event. Guests upload memories, all collected beautifully in one place — no expiry, no clutter.',
    color: '#14B8A6',
    bg: 'rgba(20, 184, 166, 0.06)',
  },
  {
    icon: '🎁',
    title: 'Digital Lifafa',
    description: 'Guests send shagun directly via UPI — Lumhe never touches the money. Animated envelopes, personal messages, instant receipts.',
    color: '#F59E0B',
    bg: 'rgba(245, 158, 11, 0.06)',
  },
  {
    icon: '🔗',
    title: 'Share Anywhere Too',
    description: 'Every invite generates a shareable link. Send on WhatsApp, Instagram, or any platform — no "Forwarded" tag, no missing details.',
    color: '#10B981',
    bg: 'rgba(16, 185, 129, 0.06)',
  },
];
---

<section id="features" class="section bg-surface-alt">
  <div class="container">
    <div class="features__header text-center reveal">
      <span class="label text-primary">Features</span>
      <h2 class="heading-xl" style="margin-top: 0.5rem;">
        Everything for Your<br/>
        <span class="underline-wave">Celebration</span>
      </h2>
      <p class="body-lg text-muted" style="max-width: 560px; margin: 1rem auto 0;">
        Replace WhatsApp broadcasts, Google Forms, cash envelopes, and scattered photo groups — with one unified platform.
      </p>
    </div>

    <div class="features__grid stagger-children" style="margin-top: var(--space-2xl);">
      {features.map((f) => (
        <div class="feature-card card-hover tilt-card">
          <div class="feature-card__icon" style={`background: ${f.bg}; color: ${f.color};`}>
            <span style="font-size: 1.5rem;">{f.icon}</span>
          </div>
          <h3 class="heading-sm" style="margin-top: 1rem;">{f.title}</h3>
          <p class="body-md text-muted" style="margin-top: 0.5rem;">{f.description}</p>
          <div class="feature-card__arrow">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <path d="M5 10H15M15 10L10 5M15 10L10 15"/>
            </svg>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .features__header { max-width: 700px; margin: 0 auto; }

  .features__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }

  .feature-card {
    background: var(--color-surface); border: 1px solid var(--color-border);
    border-radius: var(--radius-lg); padding: 2rem; position: relative; cursor: default;
    transition: transform 0.35s var(--ease-smooth), box-shadow 0.35s var(--ease-smooth), border-color 0.35s;
  }
  .feature-card:hover { border-color: var(--color-primary-light); }

  .feature-card__icon {
    width: 52px; height: 52px; border-radius: var(--radius-md);
    display: flex; align-items: center; justify-content: center;
  }

  .feature-card__arrow {
    position: absolute; top: 2rem; right: 2rem; color: var(--color-text-light);
    opacity: 0; transform: translateX(-8px); transition: all 0.3s var(--ease-smooth);
  }
  .feature-card:hover .feature-card__arrow { opacity: 1; transform: translateX(0); }

  @media (max-width: 900px) { .features__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px) { .features__grid { grid-template-columns: 1fr; } }
</style>

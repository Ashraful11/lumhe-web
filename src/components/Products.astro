---
---

<section id="products" class="section">
  <div class="container">
    <div class="text-center reveal" style="max-width: 650px; margin: 0 auto;">
      <span class="label text-primary">Our Products</span>
      <h2 class="heading-xl" style="margin-top: 0.5rem;">
        Three Products,<br/>
        <em class="font-serif">One Platform</em>
      </h2>
      <p class="body-lg text-muted" style="margin-top: 1rem;">
        From the invitation to the memories to the gift — everything your celebration needs. <strong style="color: var(--color-primary);">Completely free.</strong>
      </p>
    </div>

    <!-- Bento: featured Invitations on left, Moments + Lifafa stacked on right -->
    <div class="prod-bento reveal" style="margin-top: var(--space-2xl);">

      <!-- Featured: Invitations -->
      <div class="prod-tile prod-tile--hero">
        <div class="prod-tile__label">
          <span class="prod-dot" style="background: #FF5252;"></span>
          Invitations
        </div>
        <h3 class="heading-lg" style="color: white; margin-top: 1rem;">
          Upload, Connect,<br/>Track RSVPs
        </h3>
        <p class="body-md" style="color: rgba(255,255,255,0.8); margin-top: 0.75rem; max-width: 340px;">
          Upload your invitation in any format. Find guests by name, phone, or email inside Lumhe. Track RSVPs per event in real time.
        </p>
        <!-- Mockup: mini invite card -->
        <div class="prod-mockup-invite">
          <div class="prod-mockup-invite__card">
            <div class="prod-mockup-invite__img"></div>
            <div class="prod-mockup-invite__lines">
              <div class="prod-line" style="width: 60%;"></div>
              <div class="prod-line prod-line--sm" style="width: 40%;"></div>
            </div>
            <div class="prod-mockup-invite__rsvp">
              <span class="prod-rsvp-dot" style="background: #4CAF50;"></span>
              <div class="prod-line" style="width: 50%;"></div>
            </div>
          </div>
        </div>
        <a href="#features" class="prod-link prod-link--light">Learn More <span class="arrow">&rarr;</span></a>
      </div>

      <!-- Moments -->
      <div class="prod-tile prod-tile--moments">
        <div class="prod-tile__label">
          <span class="prod-dot" style="background: #8B5CF6;"></span>
          Moments
        </div>
        <h3 class="heading-md" style="margin-top: 0.75rem;">Shared Photo Memories</h3>
        <p class="body-sm text-muted" style="margin-top: 0.5rem;">
          A permanent photo timeline for your event. Guests upload memories — all collected beautifully in one place.
        </p>
        <!-- Mockup: photo grid -->
        <div class="prod-photo-grid">
          <div class="prod-photo" style="background: linear-gradient(135deg, #EDE7F6, #D1C4E9);"></div>
          <div class="prod-photo" style="background: linear-gradient(135deg, #E8EAF6, #C5CAE9);"></div>
          <div class="prod-photo" style="background: linear-gradient(135deg, #F3E5F5, #CE93D8);"></div>
          <div class="prod-photo" style="background: linear-gradient(135deg, #E1F5FE, #81D4FA);"></div>
        </div>
        <a href="/moments-features/creating-albums" class="prod-link">Explore Moments <span class="arrow">&rarr;</span></a>
      </div>

      <!-- Digital Lifafa -->
      <div class="prod-tile prod-tile--lifafa">
        <div class="prod-tile__label">
          <span class="prod-dot" style="background: #F59E0B;"></span>
          Digital Lifafa
        </div>
        <h3 class="heading-md" style="margin-top: 0.75rem;">Digital Cash Gifts</h3>
        <p class="body-sm text-muted" style="margin-top: 0.5rem;">
          Guests send gifts directly — Lumhe never touches the money. Beautiful animated envelopes with personal messages.
        </p>
        <!-- Mockup: envelope -->
        <div class="prod-envelope">
          <div class="prod-envelope__flap"></div>
          <div class="prod-envelope__body">
            <div class="prod-line" style="width: 70%; background: rgba(245,158,11,0.3);"></div>
            <span class="prod-envelope__amount">Gift</span>
          </div>
        </div>
        <a href="/digital-gifts/lifafa-tips" class="prod-link">Explore Lifafa <span class="arrow">&rarr;</span></a>
      </div>
    </div>
  </div>
</section>

<style>
  .prod-bento {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto auto;
    gap: 1.25rem;
  }

  .prod-tile {
    border-radius: var(--radius-xl);
    padding: clamp(1.75rem, 3vw, 2.5rem);
    position: relative;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .prod-tile:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 48px rgba(0,0,0,0.08);
  }

  /* Featured — spans full left column */
  .prod-tile--hero {
    grid-row: 1 / 3;
    background-color: #1a1a3e;
    background-image: linear-gradient(160deg, #1a1a3e 0%, #2d1b4e 60%, #3a1a3e 100%);
    display: flex;
    flex-direction: column;
  }

  /* Right tiles */
  .prod-tile--moments {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
  }

  .prod-tile--lifafa {
    background-color: #FFFDE7;
    background-image: linear-gradient(160deg, #FFFDE7, #FFF8E1);
    border: 1px solid #FFF0C2;
  }

  /* Label with dot */
  .prod-tile__label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
  }

  .prod-tile--hero .prod-tile__label { color: rgba(255,255,255,0.6); }

  .prod-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* Links */
  .prod-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-primary);
    text-decoration: none;
    margin-top: auto;
    padding-top: 1.5rem;
    transition: gap 0.3s ease;
  }

  .prod-link:hover { gap: 0.7rem; }
  .prod-link .arrow { transition: transform 0.3s ease; }
  .prod-link:hover .arrow { transform: translateX(3px); }

  .prod-link--light { color: rgba(255,255,255,0.85); }
  .prod-link--light:hover { color: white; }

  /* ── Invite mockup ── */
  .prod-mockup-invite {
    margin-top: 1.5rem;
    flex: 1;
    display: flex;
    align-items: flex-end;
  }

  .prod-mockup-invite__card {
    background: rgba(255,255,255,0.08);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: var(--radius-lg);
    padding: 1rem;
    width: 100%;
    max-width: 260px;
  }

  .prod-mockup-invite__img {
    width: 100%;
    height: 80px;
    background: linear-gradient(135deg, rgba(255,82,82,0.3), rgba(255,138,128,0.2));
    border-radius: var(--radius-md);
    margin-bottom: 0.75rem;
  }

  .prod-mockup-invite__lines {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-bottom: 0.75rem;
  }

  .prod-line {
    height: 6px;
    background: rgba(255,255,255,0.12);
    border-radius: 3px;
  }

  .prod-line--sm { height: 5px; }

  .prod-mockup-invite__rsvp {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding-top: 0.5rem;
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  .prod-rsvp-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* ── Photo grid mockup ── */
  .prod-photo-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 6px;
    margin-top: 1rem;
  }

  .prod-photo {
    aspect-ratio: 1;
    border-radius: 6px;
  }

  /* ── Envelope mockup ── */
  .prod-envelope {
    margin-top: 1rem;
    max-width: 200px;
  }

  .prod-envelope__flap {
    width: 100%;
    height: 0;
    border-left: 100px solid transparent;
    border-right: 100px solid transparent;
    border-top: 40px solid #FBBF24;
    opacity: 0.4;
  }

  .prod-envelope__body {
    background: rgba(245,158,11,0.08);
    border: 1px solid rgba(245,158,11,0.15);
    border-top: none;
    border-radius: 0 0 var(--radius-md) var(--radius-md);
    padding: 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .prod-envelope__amount {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    font-weight: 800;
    color: #D97706;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .prod-bento {
      grid-template-columns: 1fr;
    }

    .prod-tile--hero {
      grid-row: auto;
    }
  }
</style>

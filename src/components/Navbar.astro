<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 0.8rem 0;
    transition: all 0.4s var(--ease-smooth);
  }

  .navbar--scrolled {
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    padding: 0.5rem 0;
    box-shadow: 0 1px 20px rgba(0, 0, 0, 0.06);
  }

  .navbar--hidden {
    transform: translateY(-100%);
  }

  .navbar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .navbar__brand {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    color: var(--color-text);
    flex-shrink: 0;
  }

  .navbar__logo {
    transition: transform 0.3s var(--ease-bounce);
  }

  .navbar__brand:hover .navbar__logo {
    transform: rotate(-8deg) scale(1.05);
  }

  .navbar__name {
    font-family: var(--font-body);
    font-size: 1.15rem;
    font-weight: 700;
  }

  /* ── Nav links container ── */
  .navbar__links {
    display: flex;
    gap: 0.25rem;
    align-items: center;
    flex: 1;
    justify-content: center;
  }

  .nav-link {
    color: var(--color-text);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    padding: 0.5rem 0.75rem;
    border-radius: 8px;
    transition: color 0.2s, background 0.2s;
  }

  .nav-link:hover {
    color: var(--color-primary);
    background: rgba(255, 82, 82, 0.04);
  }

  /* ── Dropdown ── */
  .nav-dropdown {
    position: relative;
  }

  .nav-dropdown__trigger {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.5rem 0.75rem;
    border: none;
    background: none;
    color: var(--color-text);
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    border-radius: 8px;
    transition: color 0.2s, background 0.2s;
  }

  .nav-dropdown__trigger:hover {
    color: var(--color-primary);
    background: rgba(255, 82, 82, 0.04);
  }

  .nav-chevron {
    transition: transform 0.25s var(--ease-smooth);
    flex-shrink: 0;
  }

  .nav-dropdown:hover .nav-chevron {
    transform: rotate(180deg);
  }

  .nav-dropdown__menu {
    position: absolute;
    top: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%) translateY(6px);
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: 0.5rem;
    min-width: 260px;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.08), 0 4px 12px rgba(0, 0, 0, 0.04);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: all 0.25s var(--ease-smooth);
    z-index: 200;
  }

  /* Invisible bridge so hover doesn't break when moving to dropdown */
  .nav-dropdown__menu::before {
    content: '';
    position: absolute;
    top: -12px;
    left: 0;
    right: 0;
    height: 12px;
  }

  .nav-dropdown:hover .nav-dropdown__menu {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateX(-50%) translateY(0);
  }

  .nav-dropdown__menu a {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.65rem 0.75rem;
    color: var(--color-text);
    text-decoration: none;
    border-radius: 10px;
    transition: all 0.2s;
  }

  .nav-dropdown__menu a:hover {
    background: var(--color-surface-alt);
  }

  .nav-dropdown__menu a:hover strong {
    color: var(--color-primary);
  }

  .nav-dropdown__menu a div {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .nav-dropdown__menu a strong {
    display: block;
    font-size: 0.85rem;
    font-weight: 600;
    transition: color 0.2s;
    white-space: nowrap;
  }

  .nav-dropdown__icon {
    font-size: 1.1rem;
    line-height: 1.4;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .nav-dropdown__desc {
    display: block;
    font-size: 0.75rem;
    color: var(--color-text-muted);
    line-height: 1.4;
    white-space: nowrap;
  }

  /* ── Actions ── */
  .navbar__actions {
    display: flex;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  /* ── Hamburger ── */
  .navbar__hamburger {
    display: flex;
    flex-direction: column;
    gap: 5px;
    padding: 8px;
    border: none;
    background: none;
    cursor: pointer;
  }

  .navbar__hamburger span {
    display: block;
    width: 20px;
    height: 2px;
    background: var(--color-text);
    border-radius: 2px;
    transition: all 0.3s;
  }

  .navbar__hamburger.is-active span:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
  }

  .navbar__hamburger.is-active span:nth-child(2) {
    opacity: 0;
  }

  .navbar__hamburger.is-active span:nth-child(3) {
    transform: rotate(-45deg) translate(5px, -5px);
  }

  /* ── Mobile Menu ── */
  .mobile-menu {
    position: fixed;
    top: 60px;
    left: 0;
    right: 0;
    bottom: 0;
    background: white;
    z-index: 99;
    overflow-y: auto;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-10px);
    transition: all 0.3s var(--ease-smooth);
  }

  .mobile-menu.is-open {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .mobile-menu__inner {
    padding: 1rem 1.5rem 2rem;
  }

  .mobile-accordion {
    border-bottom: 1px solid var(--color-border);
  }

  .mobile-accordion summary {
    list-style: none;
    padding: 1rem 0;
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .mobile-accordion summary::-webkit-details-marker {
    display: none;
  }

  .mobile-accordion summary::after {
    content: '+';
    font-size: 1.2rem;
    color: var(--color-text-muted);
    transition: transform 0.2s;
  }

  .mobile-accordion[open] summary::after {
    content: '−';
  }

  .mobile-accordion__links {
    padding: 0 0 0.75rem 0.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .mobile-accordion__links a {
    display: block;
    padding: 0.5rem 0.75rem;
    color: var(--color-text);
    text-decoration: none;
    font-size: 0.875rem;
    border-radius: 8px;
    transition: all 0.2s;
  }

  .mobile-accordion__links a:hover {
    background: var(--color-surface-alt);
    color: var(--color-primary);
  }

  .mobile-menu__link {
    display: block;
    padding: 1rem 0;
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--color-text);
    text-decoration: none;
    border-bottom: 1px solid var(--color-border);
  }

  @media (max-width: 768px) {
    .navbar__actions .btn {
      padding: 0.55rem 1rem;
      font-size: 0.8rem;
    }
  }
</style>

<script>
  // Mobile hamburger toggle
  const hamburger = document.querySelector('.navbar__hamburger');
  const mobileMenu = document.querySelector('.mobile-menu');

  if (hamburger && mobileMenu) {
    hamburger.addEventListener('click', () => {
      hamburger.classList.toggle('is-active');
      mobileMenu.classList.toggle('is-open');
      document.body.style.overflow = mobileMenu.classList.contains('is-open') ? 'hidden' : '';
    });
  }
</script>

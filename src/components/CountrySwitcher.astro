---
interface Props {
  country?: string;
}

const { country = 'global' } = Astro.props;

const countryMap: Record<string, { flag: string; code: string; label: string }> = {
  global: { flag: '🌐', code: 'GLB', label: 'Global' },
  in: { flag: '🇮🇳', code: 'IN', label: 'India' },
  us: { flag: '🇺🇸', code: 'US', label: 'USA' },
  uk: { flag: '🇬🇧', code: 'UK', label: 'UK' },
};

const current = countryMap[country] ?? countryMap.global;
---

<div class="country-switcher">
  <button class="country-switcher__trigger" aria-expanded="false" aria-haspopup="true">
    <span class="country-switcher__flag">{current.flag}</span>
    <span class="country-switcher__code">{current.code}</span>
    <svg class="country-switcher__chevron" width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M2.5 4.5L6 8L9.5 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </button>
  <div class="country-switcher__dropdown">
    {Object.entries(countryMap).map(([key, { flag, label }]) => (
      <a
        class:list={['country-switcher__option', { 'is-active': key === country }]}
        href="#"
        data-country={key}
      >
        {flag} {label}
      </a>
    ))}
  </div>
</div>

<style>
  .country-switcher {
    position: relative;
  }

  .country-switcher__trigger {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.35rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: transparent;
    font-size: 0.78rem;
    cursor: pointer;
    transition: border-color 0.2s ease;
  }

  .country-switcher__trigger:hover {
    border-color: var(--color-primary);
  }

  .country-switcher__flag {
    font-size: 1rem;
    line-height: 1;
  }

  .country-switcher__code {
    text-transform: uppercase;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: var(--color-charcoal);
  }

  .country-switcher__chevron {
    width: 12px;
    height: 12px;
    transition: transform 0.2s ease;
  }

  .country-switcher.is-open .country-switcher__chevron {
    transform: rotate(180deg);
  }

  .country-switcher__dropdown {
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
    min-width: 160px;
    opacity: 0;
    pointer-events: none;
    transform: translateY(-4px);
    transition: all 0.2s ease;
    z-index: 100;
    overflow: hidden;
  }

  .country-switcher.is-open .country-switcher__dropdown {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .country-switcher__option {
    display: flex;
    gap: 0.5rem;
    padding: 0.65rem 1rem;
    font-size: 0.85rem;
    cursor: pointer;
    text-decoration: none;
    color: var(--color-charcoal);
    transition: background-color 0.15s ease;
  }

  .country-switcher__option:hover {
    background: var(--color-surface-alt);
  }

  .country-switcher__option.is-active {
    font-weight: 700;
    color: var(--color-primary);
  }
</style>

<script>
  const switcher = document.querySelector('.country-switcher');
  const trigger = switcher?.querySelector('.country-switcher__trigger');

  trigger?.addEventListener('click', () => {
    const isOpen = switcher?.classList.toggle('is-open');
    trigger.setAttribute('aria-expanded', String(isOpen));
  });

  document.addEventListener('click', (e) => {
    if (!switcher?.contains(e.target as Node)) {
      switcher?.classList.remove('is-open');
      trigger?.setAttribute('aria-expanded', 'false');
    }
  });

  const options = document.querySelectorAll('.country-switcher__option');
  const countryPrefixes = ['in', 'us', 'uk'];

  options.forEach((opt) => {
    opt.addEventListener('click', (e) => {
      e.preventDefault();
      const newCountry = opt.getAttribute('data-country');
      if (!newCountry) return;

      localStorage.setItem('lumhe-country', newCountry);

      const path = window.location.pathname;
      const segments = path.split('/').filter(Boolean);

      let cleanPath = path;
      if (segments.length > 0 && countryPrefixes.includes(segments[0])) {
        cleanPath = '/' + segments.slice(1).join('/');
      }
      if (!cleanPath || cleanPath === '/') cleanPath = '/';

      const newPath = newCountry === 'global' ? cleanPath : `/${newCountry}${cleanPath}`;
      window.location.href = newPath;
    });
  });
</script>

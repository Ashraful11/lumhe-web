---
import type { CountryCode } from '../data/countries';
import { getHomeContent } from '../data/content/resolver';

interface Props { country?: CountryCode; }
const { country = 'global' } = Astro.props;
const content = getHomeContent(country);
const { featured, pair } = content.testimonials;
---

<section id="testimonials" class="section">
  <div class="container">
    <div class="testimonials__header text-center reveal">
      <span class="label text-primary">Testimonials</span>
      <h2 class="heading-xl" style="margin-top: 0.5rem;">
        Loved by <em class="font-serif">Families</em>
      </h2>
    </div>

    <div class="testi-layout stagger-children" style="margin-top: var(--space-2xl);">
      <!-- Featured testimonial -->
      <div class="testi-featured">
        <div class="testi-featured__quote">
          <svg class="testi-quote-mark" width="48" height="48" viewBox="0 0 24 24" fill="currentColor" opacity="0.08">
            <path d="M3 21c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 5.219-2.176 5.954-2.734 5.954-.183 0-.28.126-.28.283v.526c0 .13.094.237.224.237zm14 0c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 5.219-2.176 5.954-2.734 5.954-.183 0-.28.126-.28.283v.526c0 .13.094.237.224.237z"/>
          </svg>
          <blockquote class="heading-sm" style="line-height: 1.6; color: var(--color-charcoal); font-style: italic;">
            {featured.quote}
          </blockquote>
          <div class="testi-author" style="margin-top: 2rem;">
            <div class="testi-avatar" style={`background: linear-gradient(135deg, ${featured.color}, ${featured.color}80);`}>{featured.avatar}</div>
            <div>
              <p class="heading-xs">{featured.name}</p>
              <p class="body-sm text-muted">{featured.role}</p>
            </div>
          </div>
        </div>
        <div class="testi-featured__visual">
          {featured.stats.map((stat) => (
            <div class="testi-stat-card">
              <span class="testi-stat__number" style={`color: ${stat.color};`}>{stat.number}</span>
              <span class="testi-stat__label">{stat.label}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Two smaller side-by-side -->
      <div class="testi-pair">
        <div class={`testi-card${pair[0].accent ? ' testi-card--accent' : ''}`}>
          <blockquote class="body-lg" style={`font-style: italic; color: ${pair[0].accent ? 'white' : 'var(--color-text)'}; line-height: 1.7;`}>
            &ldquo;{pair[0].quote}&rdquo;
          </blockquote>
          <div class="testi-author" style="margin-top: 1.25rem;">
            <div class="testi-avatar" style={pair[0].accent ? `background: rgba(255,255,255,0.2); border: 2px solid rgba(255,255,255,0.3);` : `background: linear-gradient(135deg, ${pair[0].color}, ${pair[0].color}80);`}>{pair[0].avatar}</div>
            <div>
              <p style={`font-weight: 600;${pair[0].accent ? ' color: white;' : ''}`}>{pair[0].name}</p>
              <p class="body-sm" style={pair[0].accent ? 'color: rgba(255,255,255,0.7);' : ''}>
                {!pair[0].accent && <Fragment><span class="text-muted">{pair[0].role}</span></Fragment>}
                {pair[0].accent && pair[0].role}
              </p>
            </div>
          </div>
          <div class="testi-tag" style={`background: ${pair[0].accent ? 'rgba(255,255,255,0.15)' : `${pair[0].tagColor}10`}; color: ${pair[0].accent ? 'white' : pair[0].tagColor};`}>{pair[0].tag}</div>
        </div>

        <div class={`testi-card${pair[1].accent ? ' testi-card--accent' : ''}`}>
          <blockquote class="body-lg" style={`font-style: italic; color: ${pair[1].accent ? 'white' : 'var(--color-text)'}; line-height: 1.7;`}>
            &ldquo;{pair[1].quote}&rdquo;
          </blockquote>
          <div class="testi-author" style="margin-top: 1.25rem;">
            <div class="testi-avatar" style={pair[1].accent ? `background: rgba(255,255,255,0.2); border: 2px solid rgba(255,255,255,0.3);` : `background: linear-gradient(135deg, ${pair[1].color}, ${pair[1].color}80);`}>{pair[1].avatar}</div>
            <div>
              <p style={`font-weight: 600;${pair[1].accent ? ' color: white;' : ''}`}>{pair[1].name}</p>
              <p class="body-sm" style={pair[1].accent ? 'color: rgba(255,255,255,0.7);' : ''}>
                {!pair[1].accent && <Fragment><span class="text-muted">{pair[1].role}</span></Fragment>}
                {pair[1].accent && pair[1].role}
              </p>
            </div>
          </div>
          <div class="testi-tag" style={`background: ${pair[1].accent ? 'rgba(255,255,255,0.15)' : `${pair[1].tagColor}10`}; color: ${pair[1].accent ? 'white' : pair[1].tagColor};`}>{pair[1].tag}</div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .testimonials__header { max-width: 500px; margin: 0 auto; }

  .testi-layout {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    max-width: 960px;
    margin-left: auto;
    margin-right: auto;
  }

  /* Featured — wide with stats on right */
  .testi-featured {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 2rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: clamp(2rem, 4vw, 3rem);
    align-items: center;
  }

  .testi-featured__quote {
    position: relative;
  }

  .testi-quote-mark {
    position: absolute;
    top: -8px;
    left: -4px;
    color: var(--color-primary);
  }

  .testi-featured__visual {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .testi-stat-card {
    background: var(--color-surface-alt);
    border-radius: var(--radius-md);
    padding: 1rem 1.25rem;
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
  }

  .testi-stat__number {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 900;
    line-height: 1;
  }

  .testi-stat__label {
    font-family: var(--font-body);
    font-size: 0.82rem;
    color: var(--color-text-muted);
  }

  /* Pair — two side-by-side */
  .testi-pair {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .testi-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: clamp(1.75rem, 3vw, 2.25rem);
    position: relative;
  }

  .testi-card--accent {
    background: linear-gradient(160deg, var(--color-charcoal), #2d1b4e);
    border-color: transparent;
  }

  .testi-tag {
    display: inline-block;
    margin-top: 1rem;
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.3rem 0.8rem;
    border-radius: var(--radius-full);
  }

  /* Shared */
  .testi-author {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .testi-avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    color: white;
    font-size: 1rem;
    flex-shrink: 0;
  }

  @media (max-width: 900px) {
    .testi-featured { grid-template-columns: 1fr; }
    .testi-pair { grid-template-columns: 1fr; }
  }
</style>

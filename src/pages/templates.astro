---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const templates = [
  { name: 'Rajasthani Palace', category: 'Wedding', gradient: 'linear-gradient(135deg, #F9E8D0, #D4A373)', emoji: '🏰' },
  { name: 'Rose Garden', category: 'Wedding', gradient: 'linear-gradient(135deg, #FF5252, #FF8A80)', emoji: '🌹' },
  { name: 'Midnight Gala', category: 'Corporate', gradient: 'linear-gradient(135deg, #1A1A2E, #16213E)', emoji: '🌙' },
  { name: 'Lavender Dreams', category: 'Birthday', gradient: 'linear-gradient(135deg, #E8D5F5, #C9B1FF)', emoji: '💜' },
  { name: 'Golden Hour', category: 'Wedding', gradient: 'linear-gradient(135deg, #FFD54F, #FF8F00)', emoji: '☀️' },
  { name: 'Neon Party', category: 'Party', gradient: 'linear-gradient(135deg, #7C3AED, #EC4899)', emoji: '🎉' },
  { name: 'Ocean Breeze', category: 'Birthday', gradient: 'linear-gradient(135deg, #06B6D4, #3B82F6)', emoji: '🌊' },
  { name: 'Minimal White', category: 'Minimal', gradient: 'linear-gradient(135deg, #F8FAFC, #E2E8F0)', emoji: '◻️' },
];
---

<Layout title="Lumhe Templates — Coming Soon" description="Pre-made invitation templates for every occasion. Coming soon to Lumhe.">
  <Navbar />

  <section class="templates-hero">
    <div class="container">
      <div class="text-center">
        <span class="label" style="color: var(--color-amber);" class="anim-first-hit delay-1">Coming Soon</span>
        <h1 class="heading-2xl anim-first-hit delay-2" style="margin-top: 0.5rem;">
          Pre-Made <em class="font-serif">Templates</em>
        </h1>
        <p class="body-lg text-muted anim-first-hit delay-3" style="max-width: 580px; margin: 1rem auto 0;">
          We're building a library of professionally designed invitation templates for every occasion.
          Pick a template, customise with your details, and go — no external design tool needed.
        </p>
        <p class="body-md anim-first-hit delay-4" style="margin-top: var(--space-md); color: var(--color-text);">
          <strong>For now</strong>, you can upload your own invitation in any format — image, video, PDF, or text — and Lumhe handles the rest.
        </p>
        <div class="anim-first-hit delay-5" style="margin-top: var(--space-lg); display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
          <a href="#" class="btn btn-primary magnetic">
            Upload Your Invitation — Free
            <span class="arrow">&rarr;</span>
          </a>
          <a href="/" class="btn btn-outline">
            Back to Home
          </a>
        </div>
      </div>

      <!-- Preview Grid (Coming Soon) -->
      <div class="template-grid stagger-children" style="margin-top: var(--space-2xl);">
        {templates.map((t) => (
          <div class="template-card" data-cat={t.category}>
            <div class="template-card__preview" style={`background: ${t.gradient};`}>
              <span style="font-size: 3rem;">{t.emoji}</span>
              <div class="template-card__coming-soon">Coming Soon</div>
            </div>
            <div class="template-card__info">
              <h3 class="heading-sm">{t.name}</h3>
              <span class="body-sm text-muted">{t.category}</span>
            </div>
          </div>
        ))}
      </div>

      <!-- Notify form -->
      <div class="notify-section reveal" style="margin-top: var(--space-2xl); text-align: center;">
        <h3 class="heading-md">Get Notified When Templates Launch</h3>
        <p class="body-md text-muted" style="margin-top: 0.5rem;">We'll let you know as soon as templates are ready.</p>
        <div style="display: flex; gap: 0.5rem; justify-content: center; margin-top: var(--space-md); max-width: 420px; margin-left: auto; margin-right: auto;">
          <input type="email" placeholder="Enter your email" style="flex: 1; padding: 0.75rem 1rem; border: 1.5px solid var(--color-border); border-radius: var(--radius-full); font-family: var(--font-body); font-size: 0.9rem; outline: none;" />
          <button class="btn btn-primary" style="flex-shrink: 0;">Notify Me</button>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .templates-hero { padding: var(--space-3xl) 0 var(--space-2xl); padding-top: calc(var(--space-3xl) + 80px); min-height: 100vh; }

  .template-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; }
  .template-card { border-radius: var(--radius-lg); overflow: hidden; background: var(--color-surface); border: 1px solid var(--color-border); opacity: 0.7; cursor: default; transition: opacity 0.3s; }
  .template-card:hover { opacity: 0.9; }
  .template-card__preview { aspect-ratio: 9/16; display: flex; flex-direction: column; align-items: center; justify-content: center; position: relative; gap: 1rem; }
  .template-card__coming-soon { background: rgba(0,0,0,0.5); color: white; padding: 0.3rem 0.8rem; border-radius: var(--radius-full); font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; }
  .template-card__info { padding: 1rem 1.25rem; display: flex; justify-content: space-between; align-items: center; }

  .notify-section { padding: var(--space-xl); background: var(--color-surface-alt); border-radius: var(--radius-xl); border: 1px solid var(--color-border); }

  @media (max-width: 900px) { .template-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 500px) { .template-grid { grid-template-columns: 1fr; max-width: 280px; margin-left: auto; margin-right: auto; } }
</style>

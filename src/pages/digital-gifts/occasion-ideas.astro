---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="Gift Ideas for Every Occasion — Lumhe" description="When and how to use Digital Lifafa for weddings, birthdays, anniversaries, baby showers, housewarming, and every Indian celebration. Send money gifts via UPI — free.">
  <Navbar />

  <!-- Hero -->
  <section class="feat-hero">
    <div class="container">
      <div class="feat-hero__inner">
        <div class="feat-hero__content">
          <div class="anim-first-hit delay-1">
            <span class="feat-badge">Every Occasion</span>
          </div>
          <h1 class="heading-2xl anim-first-hit delay-2">
            Digital Lifafa for<br/>
            <em>Every Celebration</em>
          </h1>
          <p class="body-lg text-muted anim-first-hit delay-3" style="max-width: 520px;">
            Weddings, birthdays, anniversaries, baby showers — wherever you'd hand over a cash envelope, Digital Lifafa replaces it beautifully. Send money via UPI, directly to the host.
          </p>
          <div class="feat-hero__cta anim-first-hit delay-4">
            <a href="#" class="btn btn-primary magnetic">Send Digital Lifafa — Free <span class="arrow">&rarr;</span></a>
          </div>
        </div>
        <div class="feat-hero__visual anim-first-hit delay-3">
          <img src="/images/lumhe/digital_lifafa.png" alt="Digital Lifafa for every occasion" class="feat-hero__img"/>
        </div>
      </div>
    </div>
  </section>

  <!-- Tabbed Occasion Selector (CSS-only) -->
  <section class="section bg-surface-alt">
    <div class="container">
      <div class="text-center reveal" style="max-width: 600px; margin: 0 auto;">
        <span class="label text-primary">Browse by Occasion</span>
        <h2 class="heading-xl" style="margin-top: 0.5rem;">
          Choose Your<br/><em class="font-serif">Occasion</em>
        </h2>
      </div>

      <div class="carousel-stack reveal" style="margin-top: var(--space-2xl);">
        <!-- Hidden radio inputs for CSS-only navigation -->
        <input type="radio" name="occasion-card" id="card-wedding" class="card-radio" checked />
        <input type="radio" name="occasion-card" id="card-birthday" class="card-radio" />
        <input type="radio" name="occasion-card" id="card-anniversary" class="card-radio" />
        <input type="radio" name="occasion-card" id="card-babyshower" class="card-radio" />
        <input type="radio" name="occasion-card" id="card-housewarming" class="card-radio" />
        <input type="radio" name="occasion-card" id="card-farewell" class="card-radio" />

        <!-- Navigation arrows -->
        <div class="stack-nav">
          <div class="stack-nav__dots">
            <label for="card-wedding" class="stack-dot">Wedding</label>
            <label for="card-birthday" class="stack-dot">Birthday</label>
            <label for="card-anniversary" class="stack-dot">Anniversary</label>
            <label for="card-babyshower" class="stack-dot">Baby Shower</label>
            <label for="card-housewarming" class="stack-dot">Housewarming</label>
            <label for="card-farewell" class="stack-dot">Farewell</label>
          </div>
        </div>

        <!-- Card stack -->
        <div class="stack-cards">
          <!-- Wedding -->
          <div class="stack-card stack-card--wedding" id="scard-wedding">
            <div class="stack-card__header">
              <h3 class="stack-card__title">Wedding Shagun</h3>
              <p class="stack-card__desc">Wedding shagun is the most common use of lifafa in India. Digital Lifafa lets guests send blessings even if they can't attend.</p>
            </div>
            <div class="stack-card__bars">
              <div class="bar-row">
                <span class="bar-row__label">Close Family</span>
                <div class="bar-row__track"><div class="bar-row__fill" style="width: 100%;"></div></div>
                <span class="bar-row__value">&#8377;5,001 &ndash; &#8377;21,001</span>
              </div>
              <div class="bar-row">
                <span class="bar-row__label">Extended Family</span>
                <div class="bar-row__track"><div class="bar-row__fill" style="width: 55%;"></div></div>
                <span class="bar-row__value">&#8377;2,101 &ndash; &#8377;5,001</span>
              </div>
              <div class="bar-row">
                <span class="bar-row__label">Friends</span>
                <div class="bar-row__track"><div class="bar-row__fill" style="width: 35%;"></div></div>
                <span class="bar-row__value">&#8377;1,001 &ndash; &#8377;3,001</span>
              </div>
              <div class="bar-row">
                <span class="bar-row__label">Colleagues</span>
                <div class="bar-row__track"><div class="bar-row__fill" style="width: 20%;"></div></div>
                <span class="bar-row__value">&#8377;501 &ndash; &#8377;2,001</span>
              </div>
            </div>
            <ol class="stack-card__tips">
              <li>Use auspicious amounts ending in 1 (501, 1001, 2101)</li>
              <li>Send for each function — mehendi, wedding, reception</li>
              <li>Add a personal blessing mentioning the couple</li>
            </ol>
            <a href="#" class="btn btn-primary magnetic">Send Wedding Shagun <span class="arrow">&rarr;</span></a>
          </div>

          <!-- Birthday -->
          <div class="stack-card stack-card--birthday" id="scard-birthday">
            <div class="stack-card__header">
              <h3 class="stack-card__title">Birthday Gifts</h3>
              <p class="stack-card__desc">Not sure what to buy? Let them choose. A Digital Lifafa with a heartfelt message is the most appreciated birthday gift.</p>
            </div>
            <div class="stack-card__bars">
              <div class="bar-row">
                <span class="bar-row__label">Close Family</span>
                <div class="bar-row__track"><div class="bar-row__fill" style="width: 60%;"></div></div>
                <span class="bar-row__value">&#8377;1,001 &ndash; &#8377;5,001</span>
              </div>
              <div class="bar-row">
                <span class="bar-row__label">Extended Family</span>
                <div class="bar-row__track"><div class="bar-row__fill" style="width: 25%;"></div></div>
                <span class="bar-row__value">&#8377;501 &ndash; &#8377;1,001</span>
              </div>
              <div class="bar-row">
                <span class="bar-row__label">Friends</span>
                <div class="bar-row__track"><div class="bar-row__fill" style="width: 18%;"></div></div>
                <span class="bar-row__value">&#8377;251 &ndash; &#8377;1,001</span>
              </div>
              <div class="bar-row">
                <span class="bar-row__label">Colleagues</span>
                <div class="bar-row__track"><div class="bar-row__fill" style="width: 10%;"></div></div>
                <span class="bar-row__value">&#8377;251 &ndash; &#8377;501</span>
              </div>
            </div>
            <ol class="stack-card__tips">
              <li>Fun and playful message works best</li>
              <li>For kids, even a small amount with a sweet message goes a long way</li>
              <li>Great for group contributions from friend circles</li>
            </ol>
            <a href="#" class="btn btn-primary magnetic">Send Birthday Gift <span class="arrow">&rarr;</span></a>
          </div>

          <!-- Anniversary -->
          <div class="stack-card stack-card--anniversary" id="scard-anniversary">
            <div class="stack-card__header">
              <h3 class="stack-card__title">Anniversary Blessings</h3>
              <p class="stack-card__desc">Milestone anniversaries — 25th, 50th — often involve gifting from family and close friends. Honour the couple's journey beautifully.</p>
            </div>
            <div class="stack-card__bars">
              <div class="bar-row">
                <span class="bar-row__label">Close Family</span>
                <div class="bar-row__track"><div class="bar-row__fill" style="width: 75%;"></div></div>
                <span class="bar-row__value">&#8377;2,001 &ndash; &#8377;11,001</span>
              </div>
              <div class="bar-row">
                <span class="bar-row__label">Extended Family</span>
                <div class="bar-row__track"><div class="bar-row__fill" style="width: 38%;"></div></div>
                <span class="bar-row__value">&#8377;1,001 &ndash; &#8377;3,001</span>
              </div>
              <div class="bar-row">
                <span class="bar-row__label">Friends</span>
                <div class="bar-row__track"><div class="bar-row__fill" style="width: 22%;"></div></div>
                <span class="bar-row__value">&#8377;501 &ndash; &#8377;2,001</span>
              </div>
              <div class="bar-row">
                <span class="bar-row__label">Colleagues</span>
                <div class="bar-row__track"><div class="bar-row__fill" style="width: 14%;"></div></div>
                <span class="bar-row__value">&#8377;501 &ndash; &#8377;1,001</span>
              </div>
            </div>
            <ol class="stack-card__tips">
              <li>Mention their years together in your message</li>
              <li>Family across cities can contribute effortlessly</li>
              <li>Your message becomes a keepsake they can revisit</li>
            </ol>
            <a href="#" class="btn btn-primary magnetic">Send Anniversary Gift <span class="arrow">&rarr;</span></a>
          </div>

          <!-- Baby Shower -->
          <div class="stack-card stack-card--babyshower" id="scard-babyshower">
            <div class="stack-card__header">
              <h3 class="stack-card__title">Baby Shower Contributions</h3>
              <p class="stack-card__desc">New parents have a thousand things to buy. Send a Digital Lifafa and let them decide what they need most.</p>
            </div>
            <div class="stack-card__bars">
              <div class="bar-row">
                <span class="bar-row__label">Close Family</span>
                <div class="bar-row__track"><div class="bar-row__fill" style="width: 55%;"></div></div>
                <span class="bar-row__value">&#8377;2,001 &ndash; &#8377;5,001</span>
              </div>
              <div class="bar-row">
                <span class="bar-row__label">Extended Family</span>
                <div class="bar-row__track"><div class="bar-row__fill" style="width: 28%;"></div></div>
                <span class="bar-row__value">&#8377;1,001 &ndash; &#8377;2,001</span>
              </div>
              <div class="bar-row">
                <span class="bar-row__label">Friends</span>
                <div class="bar-row__track"><div class="bar-row__fill" style="width: 16%;"></div></div>
                <span class="bar-row__value">&#8377;501 &ndash; &#8377;1,001</span>
              </div>
              <div class="bar-row">
                <span class="bar-row__label">Colleagues</span>
                <div class="bar-row__track"><div class="bar-row__fill" style="width: 16%;"></div></div>
                <span class="bar-row__value">&#8377;501 &ndash; &#8377;1,001</span>
              </div>
            </div>
            <ol class="stack-card__tips">
              <li>No duplicate gifts — a common baby shower problem solved</li>
              <li>Parents can use money for exactly what they need</li>
              <li>Friends abroad can participate just as easily</li>
            </ol>
            <a href="#" class="btn btn-primary magnetic">Send Baby Shower Gift <span class="arrow">&rarr;</span></a>
          </div>

          <!-- Housewarming -->
          <div class="stack-card stack-card--housewarming" id="scard-housewarming">
            <div class="stack-card__header">
              <h3 class="stack-card__title">Griha Pravesh Gifts</h3>
              <p class="stack-card__desc">A new home is a huge milestone. Digital Lifafa lets them use your gift for furniture, appliances, or anything they actually need.</p>
            </div>
            <div class="stack-card__bars">
              <div class="bar-row">
                <span class="bar-row__label">Close Family</span>
                <div class="bar-row__track"><div class="bar-row__fill" style="width: 75%;"></div></div>
                <span class="bar-row__value">&#8377;2,001 &ndash; &#8377;11,001</span>
              </div>
              <div class="bar-row">
                <span class="bar-row__label">Extended Family</span>
                <div class="bar-row__track"><div class="bar-row__fill" style="width: 30%;"></div></div>
                <span class="bar-row__value">&#8377;1,001 &ndash; &#8377;2,101</span>
              </div>
              <div class="bar-row">
                <span class="bar-row__label">Friends</span>
                <div class="bar-row__track"><div class="bar-row__fill" style="width: 18%;"></div></div>
                <span class="bar-row__value">&#8377;501 &ndash; &#8377;1,101</span>
              </div>
              <div class="bar-row">
                <span class="bar-row__label">Colleagues</span>
                <div class="bar-row__track"><div class="bar-row__fill" style="width: 14%;"></div></div>
                <span class="bar-row__value">&#8377;501 &ndash; &#8377;1,001</span>
              </div>
            </div>
            <ol class="stack-card__tips">
              <li>More useful than a random home decor item</li>
              <li>Send blessings for the new home with your message</li>
              <li>Works whether you attend or send from a distance</li>
            </ol>
            <a href="#" class="btn btn-primary magnetic">Send Housewarming Gift <span class="arrow">&rarr;</span></a>
          </div>

          <!-- Farewell -->
          <div class="stack-card stack-card--farewell" id="scard-farewell">
            <div class="stack-card__header">
              <h3 class="stack-card__title">Farewell Gifts</h3>
              <p class="stack-card__desc">When a colleague, teacher, or friend is moving on — a collective Digital Lifafa pools money from the group effortlessly.</p>
            </div>
            <div class="stack-card__bars">
              <div class="bar-row">
                <span class="bar-row__label">Close Family</span>
                <div class="bar-row__track"><div class="bar-row__fill" style="width: 30%;"></div></div>
                <span class="bar-row__value">&#8377;1,001 &ndash; &#8377;2,001</span>
              </div>
              <div class="bar-row">
                <span class="bar-row__label">Extended Family</span>
                <div class="bar-row__track"><div class="bar-row__fill" style="width: 18%;"></div></div>
                <span class="bar-row__value">&#8377;501 &ndash; &#8377;1,001</span>
              </div>
              <div class="bar-row">
                <span class="bar-row__label">Friends</span>
                <div class="bar-row__track"><div class="bar-row__fill" style="width: 14%;"></div></div>
                <span class="bar-row__value">&#8377;301 &ndash; &#8377;1,001</span>
              </div>
              <div class="bar-row">
                <span class="bar-row__label">Colleagues</span>
                <div class="bar-row__track"><div class="bar-row__fill" style="width: 8%;"></div></div>
                <span class="bar-row__value">&#8377;251 &ndash; &#8377;501</span>
              </div>
            </div>
            <ol class="stack-card__tips">
              <li>Everyone can add their own personal farewell message</li>
              <li>Remote team members participate just as easily</li>
              <li>No more passing around an envelope in the office</li>
            </ol>
            <a href="#" class="btn btn-primary magnetic">Send Farewell Gift <span class="arrow">&rarr;</span></a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Cash vs Digital Comparison -->
  <section class="section">
    <div class="container">
      <div class="text-center reveal" style="max-width: 600px; margin: 0 auto;">
        <span class="label text-primary">Why Switch</span>
        <h2 class="heading-xl" style="margin-top: 0.5rem;">
          Cash Envelope vs<br/><em class="font-serif">Digital Lifafa</em>
        </h2>
      </div>

      <div class="comparison reveal" style="margin-top: var(--space-2xl);">
        <!-- Traditional side -->
        <div class="comparison__side comparison__side--old">
          <h3 class="heading-md comparison__title">Traditional Cash Envelope</h3>
          <div class="comparison__items">
            <div class="comparison__item">
              <span class="comparison__mark comparison__mark--x">&#10007;</span>
              <p class="body-md">Need to visit ATM for exact cash</p>
            </div>
            <div class="comparison__item">
              <span class="comparison__mark comparison__mark--x">&#10007;</span>
              <p class="body-md">Can be lost or misplaced at busy events</p>
            </div>
            <div class="comparison__item">
              <span class="comparison__mark comparison__mark--x">&#10007;</span>
              <p class="body-md">No record — easy to forget who gave what</p>
            </div>
            <div class="comparison__item">
              <span class="comparison__mark comparison__mark--x">&#10007;</span>
              <p class="body-md">Can't gift if you can't attend in person</p>
            </div>
            <div class="comparison__item">
              <span class="comparison__mark comparison__mark--x">&#10007;</span>
              <p class="body-md">No personal message preserved for later</p>
            </div>
          </div>
        </div>

        <!-- VS badge -->
        <div class="comparison__vs">
          <span class="comparison__vs-badge">VS</span>
        </div>

        <!-- Digital side -->
        <div class="comparison__side comparison__side--new">
          <h3 class="heading-md comparison__title">Digital Lifafa</h3>
          <div class="comparison__items">
            <div class="comparison__item">
              <span class="comparison__mark comparison__mark--check">&#10003;</span>
              <p class="body-md">Send any amount via UPI in seconds</p>
            </div>
            <div class="comparison__item">
              <span class="comparison__mark comparison__mark--check">&#10003;</span>
              <p class="body-md">Secure — money goes directly to host's bank</p>
            </div>
            <div class="comparison__item">
              <span class="comparison__mark comparison__mark--check">&#10003;</span>
              <p class="body-md">Automatic receipts and gift tracking</p>
            </div>
            <div class="comparison__item">
              <span class="comparison__mark comparison__mark--check">&#10003;</span>
              <p class="body-md">Gift from any city or country, no barriers</p>
            </div>
            <div class="comparison__item">
              <span class="comparison__mark comparison__mark--check">&#10003;</span>
              <p class="body-md">Messages and voice notes preserved forever</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Quick Stats Bar -->
  <section class="section stats-section">
    <div class="container">
      <div class="stats-bar stagger-children">
        <div class="stats-tile">
          <span class="stats-tile__number">7+</span>
          <p class="stats-tile__desc">Occasions Supported</p>
        </div>
        <div class="stats-tile">
          <span class="stats-tile__number">&#8377;0</span>
          <p class="stats-tile__desc">Platform Fee</p>
        </div>
        <div class="stats-tile">
          <span class="stats-tile__number">Instant</span>
          <p class="stats-tile__desc">Delivery to Host</p>
        </div>
        <div class="stats-tile">
          <span class="stats-tile__number">&#10003;</span>
          <p class="stats-tile__desc">Personal Messages Included</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section" style="padding-bottom: var(--space-3xl);">
    <div class="container">
      <div class="feat-cta reveal-scale">
        <h2 class="heading-xl" style="color: white;">
          Every Occasion Deserves<br/><em class="font-serif">Beautiful Gifting</em>
        </h2>
        <p class="body-lg" style="margin-top: 1rem; color: rgba(255,255,255,0.8); max-width: 480px; margin-left: auto; margin-right: auto;">
          Send Digital Lifafa for any celebration. Beautiful envelopes, personal messages, direct UPI transfer. Completely free.
        </p>
        <a href="#" class="btn btn-cta-white" style="margin-top: var(--space-lg);">
          Send Digital Lifafa — Free <span class="arrow">&rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  @import '../../styles/global.css';

  .feat-hero {
    min-height: 90vh;
    display: flex;
    align-items: center;
    padding: var(--space-3xl) 0;
    padding-top: calc(var(--space-3xl) + 80px);
    background: linear-gradient(180deg, var(--color-surface-warm) 0%, var(--color-surface) 60%);
  }

  .feat-hero__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-2xl);
    align-items: center;
  }

  .feat-hero__content { display: flex; flex-direction: column; gap: var(--space-md); }

  .feat-badge {
    font-family: var(--font-body); font-size: 0.7rem; font-weight: 700;
    letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-primary);
    background: rgba(255,82,82,0.06); padding: 0.4rem 1.2rem; border-radius: var(--radius-full);
    display: inline-block;
  }

  .feat-hero__content h1 { color: var(--color-charcoal); }
  .feat-hero__content h1 em { color: var(--color-primary); font-style: italic; }

  .feat-hero__cta { margin-top: var(--space-sm); }

  .feat-hero__img {
    width: 100%; max-width: 440px; border-radius: var(--radius-xl);
    box-shadow: var(--shadow-lg); margin: 0 auto; display: block;
  }

  /* ===== ROTATING CARD STACK (CSS-only) ===== */
  .carousel-stack {
    max-width: 640px;
    margin-left: auto;
    margin-right: auto;
  }

  .card-radio {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  /* Navigation dots */
  .stack-nav {
    display: flex;
    justify-content: center;
    margin-bottom: 2rem;
  }

  .stack-nav__dots {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .stack-dot {
    display: inline-block;
    padding: 0.45rem 1.1rem;
    border-radius: var(--radius-full);
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--color-text-muted);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    cursor: pointer;
    transition: all 0.3s ease;
    white-space: nowrap;
  }

  .stack-dot:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  /* Active dot states */
  #card-wedding:checked ~ .stack-nav .stack-dot:nth-child(1),
  #card-birthday:checked ~ .stack-nav .stack-dot:nth-child(2),
  #card-anniversary:checked ~ .stack-nav .stack-dot:nth-child(3),
  #card-babyshower:checked ~ .stack-nav .stack-dot:nth-child(4),
  #card-housewarming:checked ~ .stack-nav .stack-dot:nth-child(5),
  #card-farewell:checked ~ .stack-nav .stack-dot:nth-child(6) {
    background: var(--color-primary);
    color: white;
    border-color: var(--color-primary);
  }

  /* Card stack container */
  .stack-cards {
    position: relative;
    min-height: 520px;
  }

  /* Individual cards */
  .stack-card {
    position: absolute;
    inset: 0;
    border-radius: var(--radius-xl);
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    opacity: 0;
    transform: scale(0.92) translateY(20px);
    pointer-events: none;
    transition: opacity 0.4s ease, transform 0.4s ease;
  }

  /* Unique gradient per card */
  .stack-card--wedding { background: linear-gradient(160deg, #FFF5F5 0%, #FFE8E8 40%, #FFF0F0 100%); border: 1px solid rgba(255, 82, 82, 0.15); }
  .stack-card--birthday { background: linear-gradient(160deg, #FFF8E1 0%, #FFF3CC 40%, #FFFDE7 100%); border: 1px solid rgba(255, 183, 77, 0.2); }
  .stack-card--anniversary { background: linear-gradient(160deg, #F3E5F5 0%, #EDE0F5 40%, #F8F0FC 100%); border: 1px solid rgba(171, 71, 188, 0.15); }
  .stack-card--babyshower { background: linear-gradient(160deg, #E8F5E9 0%, #DFF0E1 40%, #F0F8F0 100%); border: 1px solid rgba(102, 187, 106, 0.2); }
  .stack-card--housewarming { background: linear-gradient(160deg, #E3F2FD 0%, #DCEEFB 40%, #EFF6FF 100%); border: 1px solid rgba(66, 165, 245, 0.2); }
  .stack-card--farewell { background: linear-gradient(160deg, #FFF3E0 0%, #FFE8CC 40%, #FFF8F0 100%); border: 1px solid rgba(255, 152, 0, 0.2); }

  /* Show active card */
  #card-wedding:checked ~ .stack-cards #scard-wedding,

---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="Video Memories for Your Celebrations — Lumhe" description="Capture video moments at weddings, birthdays, and parties. Store them permanently in Lumhe Moments — no expiry, no app downloads, completely free.">
  <Navbar />

  <!-- Hero -->
  <section class="feat-hero">
    <div class="container">
      <div class="feat-hero__inner">
        <div class="feat-hero__content">
          <div class="anim-first-hit delay-1">
            <span class="feat-badge">Moments</span>
          </div>
          <h1 class="heading-2xl anim-first-hit delay-2">
            Video Memories<br/>
            <em>That Last Forever</em>
          </h1>
          <p class="body-lg text-muted anim-first-hit delay-3" style="max-width: 520px;">
            Photos capture a frame. Videos capture the feeling. Record the laughter, the music, the speeches — and store them permanently in Lumhe Moments where they'll never expire.
          </p>
          <div class="feat-hero__cta anim-first-hit delay-4">
            <a href="#" class="btn btn-primary magnetic">Try Lumhe Moments — Free <span class="arrow">&rarr;</span></a>
          </div>
        </div>
        <div class="feat-hero__visual anim-first-hit delay-3">
          <div class="video-hero-visual">
            <div class="video-play-icon">&#9654;</div>
            <p class="body-md" style="margin-top: 0.75rem; color: var(--color-charcoal); font-weight: 600;">Every moment, preserved</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Dark Cinematic Film Strip Section -->
  <section class="section film-section">
    <div class="container">
      <div class="text-center reveal" style="max-width: 600px; margin: 0 auto;">
        <span class="label" style="color: var(--color-primary);">What to Capture</span>
        <h2 class="heading-xl" style="margin-top: 0.5rem; color: white;">
          Videos Worth<br/><em class="font-serif" style="color: var(--color-primary);">Recording</em>
        </h2>
        <p class="body-lg" style="margin-top: 1rem; color: rgba(255,255,255,0.6);">
          Not sure what to film? These are the moments your future self will thank you for capturing.
        </p>
      </div>

      <div class="film-strip-wrapper reveal" style="margin-top: var(--space-2xl);">
        <div class="film-strip">
          <div class="film-sprockets film-sprockets--top"></div>
          <div class="film-frames stagger-children">
            <div class="film-frame">
              <div class="film-frame__screen">
                <div class="film-frame__gradient film-grad-1"></div>
                <div class="film-frame__play">
                  <div class="film-play-btn"></div>
                </div>
              </div>
              <h3 class="heading-sm" style="color: white; margin-top: 1rem;">Ceremony</h3>
              <p class="body-sm" style="color: rgba(255,255,255,0.6);">The vows, the pheras, the ring exchange — defining moments that deserve more than a photo.</p>
            </div>
            <div class="film-frame">
              <div class="film-frame__screen">
                <div class="film-frame__gradient film-grad-2"></div>
                <div class="film-frame__play">
                  <div class="film-play-btn"></div>
                </div>
              </div>
              <h3 class="heading-sm" style="color: white; margin-top: 1rem;">Speeches</h3>
              <p class="body-sm" style="color: rgba(255,255,255,0.6);">The father's speech, the best friend's toast — personal words that deserve to be saved in full.</p>
            </div>
            <div class="film-frame">
              <div class="film-frame__screen">
                <div class="film-frame__gradient film-grad-3"></div>
                <div class="film-frame__play">
                  <div class="film-play-btn"></div>
                </div>
              </div>
              <h3 class="heading-sm" style="color: white; margin-top: 1rem;">Dance</h3>
              <p class="body-sm" style="color: rgba(255,255,255,0.6);">The sangeet, the first dance, kids going wild — music and movement only work on video.</p>
            </div>
            <div class="film-frame">
              <div class="film-frame__screen">
                <div class="film-frame__gradient film-grad-4"></div>
                <div class="film-frame__play">
                  <div class="film-play-btn"></div>
                </div>
              </div>
              <h3 class="heading-sm" style="color: white; margin-top: 1rem;">Behind-the-Scenes</h3>
              <p class="body-sm" style="color: rgba(255,255,255,0.6);">Getting ready, last-minute decorations, nervous energy — raw clips often become the most cherished.</p>
            </div>
          </div>
          <div class="film-sprockets film-sprockets--bottom"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Platform Comparison -->
  <section class="section">
    <div class="container">
      <div class="text-center reveal" style="max-width: 600px; margin: 0 auto;">
        <span class="label text-primary">No Expiry</span>
        <h2 class="heading-xl" style="margin-top: 0.5rem;">
          Permanent Storage.<br/><em class="font-serif">Not 24 Hours.</em>
        </h2>
        <p class="body-lg text-muted" style="margin-top: 1rem;">
          See how Lumhe Moments compares to the platforms you already use.
        </p>
      </div>

      <div class="platforms stagger-children" style="margin-top: var(--space-2xl);">
        <div class="platform-col platform-col--faded">
          <div class="platform-col__icon-wrap">
            <svg class="platform-col__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="32" height="32">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
            </svg>
          </div>
          <h3 class="heading-md">Instagram Stories</h3>
          <div class="platform-col__stat">24 hours</div>
          <p class="body-md text-muted">Your celebration video disappears after a day. Guests who missed it never see it. Gone forever.</p>
          <ul class="platform-col__limits">
            <li>Disappears in 24h</li>
            <li>Only poster has access</li>
            <li>Compressed quality</li>
          </ul>
        </div>

        <div class="platform-col platform-col--faded">
          <div class="platform-col__icon-wrap">
            <svg class="platform-col__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="32" height="32">
              <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
            </svg>
          </div>
          <h3 class="heading-md">WhatsApp Status</h3>
          <div class="platform-col__stat">Buried & compressed</div>
          <p class="body-md text-muted">Videos get compressed to unwatchable quality. Then they're buried under hundreds of messages within hours.</p>
          <ul class="platform-col__limits">
            <li>Heavy compression</li>
            <li>Lost in group chats</li>
            <li>Media auto-deletes</li>
          </ul>
        </div>

        <div class="platform-col platform-col--highlighted">
          <div class="platform-col__badge">Recommended</div>
          <div class="platform-col__icon-wrap platform-col__icon-wrap--primary">
            <svg class="platform-col__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="32" height="32">
              <path d="M18.178 8c5.096 0 5.096 8 0 8-5.095 0-7.133-8-12.739-8-4.585 0-4.585 8 0 8 5.606 0 7.644-8 12.74-8z"/>
            </svg>
          </div>
          <h3 class="heading-md" style="color: var(--color-primary);">Lumhe Moments</h3>
          <div class="platform-col__stat platform-col__stat--primary">Forever</div>
          <p class="body-md text-muted">Your videos stay on your timeline permanently. No expiry, no compression, no chaos. Open the link anytime.</p>
          <ul class="platform-col__benefits">
            <li>No expiry ever</li>
            <li>Original quality</li>
            <li>No app needed</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works — Vertical Timeline -->
  <section class="section bg-surface-alt">
    <div class="container">
      <div class="text-center reveal" style="max-width: 600px; margin: 0 auto;">
        <span class="label text-primary">How It Works</span>
        <h2 class="heading-xl" style="margin-top: 0.5rem;">
          Three Simple<br/><em class="font-serif">Steps</em>
        </h2>
        <p class="body-lg text-muted" style="margin-top: 1rem;">
          Upload, collect, and relive — it's that easy.
        </p>
      </div>

      <div class="timeline" style="margin-top: var(--space-2xl);">
        <div class="timeline__line"></div>

        <div class="timeline__step reveal" style="transition-delay: 0.1s;">
          <div class="timeline__marker">
            <span class="timeline__num">1</span>
          </div>
          <div class="timeline__card">
            <h3 class="heading-md">Record & Upload</h3>
            <p class="body-md text-muted">Capture video clips on your phone during the celebration. Open the Moments link and upload them directly — no app download, no account needed.</p>
          </div>
        </div>

        <div class="timeline__step reveal" style="transition-delay: 0.2s;">
          <div class="timeline__marker">
            <span class="timeline__num">2</span>
          </div>
          <div class="timeline__card">
            <h3 class="heading-md">Guests Add Their Videos</h3>
            <p class="body-md text-muted">Share the same Moments link with all your guests. Everyone uploads their unique video clips — the ceremony from different angles, candid backstage moments, surprise reactions.</p>
          </div>
        </div>

        <div class="timeline__step reveal" style="transition-delay: 0.3s;">
          <div class="timeline__marker">
            <span class="timeline__num">3</span>
          </div>
          <div class="timeline__card">
            <h3 class="heading-md">Relive Anytime</h3>
            <p class="body-md text-muted">All videos live in one beautiful, shared timeline. Open the link months or years later — everything is still there. Download, share, or simply relive the celebration.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section" style="padding-bottom: var(--space-3xl);">
    <div class="container">
      <div class="feat-cta reveal-scale">
        <h2 class="heading-xl" style="color: white;">
          Save Every Video<br/><em class="font-serif">From Your Celebration</em>
        </h2>
        <p class="body-lg" style="margin-top: 1rem; color: rgba(255,255,255,0.8); max-width: 480px; margin-left: auto; margin-right: auto;">
          Let every guest contribute their video clips to one permanent, shared timeline. All free. Always.
        </p>
        <a href="#" class="btn btn-cta-white" style="margin-top: var(--space-lg);">
          Start Collecting Videos — Free <span class="arrow">&rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  @import '../../styles/global.css';

  .feat-hero {
    min-height: 90vh;
    display: flex;
    align-items: center;
    padding: var(--space-3xl) 0;
    padding-top: calc(var(--space-3xl) + 80px);
    background: linear-gradient(180deg, var(--color-surface-warm) 0%, var(--color-surface) 60%);
  }

  .feat-hero__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-2xl);
    align-items: center;
  }

  .feat-hero__content { display: flex; flex-direction: column; gap: var(--space-md); }

  .feat-badge {
    font-family: var(--font-body); font-size: 0.7rem; font-weight: 700;
    letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-primary);
    background: rgba(255,82,82,0.06); padding: 0.4rem 1.2rem; border-radius: var(--radius-full);
    display: inline-block;
  }

  .feat-hero__content h1 { color: var(--color-charcoal); }
  .feat-hero__content h1 em { color: var(--color-primary); font-style: italic; }

  .feat-hero__cta { margin-top: var(--space-sm); }

  .video-hero-visual {
    background: var(--color-surface-alt); border: 2px solid var(--color-border);
    border-radius: var(--radius-xl); padding: clamp(3rem, 5vw, 5rem);
    text-align: center; max-width: 440px; margin: 0 auto;
    aspect-ratio: 4/3; display: flex; flex-direction: column;
    align-items: center; justify-content: center;
  }

  .video-play-icon {
    width: 80px; height: 80px; border-radius: 50%;
    background: var(--color-primary); color: white;
    display: flex; align-items: center; justify-content: center;
    font-size: 2rem; box-shadow: var(--shadow-lg);
  }

  /* =============================================
     DARK CINEMATIC FILM STRIP SECTION
     ============================================= */
  .film-section {
    background: var(--color-charcoal);
    position: relative;
    overflow: hidden;
  }

  .film-strip-wrapper {
    overflow: hidden;
  }

  .film-strip {
    position: relative;
  }

  .film-sprockets {
    height: 20px;
    background-image: radial-gradient(circle 5px at 5px 10px, rgba(255,255,255,0.15) 4px, transparent 5px);
    background-size: 28px 20px;
    background-repeat: repeat-x;
  }

  .film-sprockets--top { margin-bottom: 1.5rem; }
  .film-sprockets--bottom { margin-top: 1.5rem; }

  .film-frames {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  .film-frame {
    text-align: center;
  }

  .film-frame__screen {
    aspect-ratio: 16/9;
    border-radius: var(--radius-md);
    position: relative;
    overflow: hidden;
    border: 2px solid rgba(255,255,255,0.1);
    cursor: pointer;
    transition: border-color 0.3s ease;
  }

  .film-frame:hover .film-frame__screen {
    border-color: var(--color-primary);
  }

  .film-frame__gradient {
    position: absolute;
    inset: 0;
  }

  .film-grad-1 { background: linear-gradient(135deg, #2d1b4e, #4a1942, #1a1a2e); }
  .film-grad-2 { background: linear-gradient(135deg, #1b3a4e, #1a2e42, #1a1a2e); }
  .film-grad-3 { background: linear-gradient(135deg, #4e1b2d, #421a30, #1a1a2e); }
  .film-grad-4 { background: linear-gradient(135deg, #1b4e3a, #1a4232, #1a1a2e); }

  .film-frame__play {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .film-play-btn {
    width: 0;
    height: 0;
    border-style: solid;
    border-width: 12px 0 12px 20px;
    border-color: transparent transparent transparent rgba(255,255,255,0.7);
    transition: border-color 0.3s ease;
  }

  .film-frame:hover .film-play-btn {
    border-color: transparent transparent transparent var(--color-primary);
  }

  /* =============================================
     PLATFORM COMPARISON — Three tall columns
     ============================================= */
  .platforms {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    max-width: 960px;
    margin-left: auto;
    margin-right: auto;
    align-items: stretch;
  }

  .platform-col {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 2.5rem 2rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    transition: transform 0.35s ease, box-shadow 0.35s ease;
  }

  .platform-col--faded {
    opacity: 0.75;
  }

  .platform-col--faded:hover {
    opacity: 1;
  }

  .platform-col--highlighted {
    border: 2px solid var(--color-primary);
    box-shadow: 0 8px 32px rgba(255, 82, 82, 0.12);
    transform: scale(1.03);
  }

  .platform-col--highlighted:hover {
    transform: scale(1.05);
    box-shadow: 0 12px 40px rgba(255, 82, 82, 0.18);
  }

  .platform-col__badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-primary);
    color: white;
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.3rem 1rem;
    border-radius: var(--radius-full);
    white-space: nowrap;
  }

  .platform-col__icon-wrap {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: var(--color-surface-alt);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.25rem;
    color: var(--color-text-muted);
  }

  .platform-col__icon-wrap--primary {
    background: rgba(255, 82, 82, 0.08);
    color: var(--color-primary);
  }

  .platform-col__icon { width: 28px; height: 28px; }

  .platform-col__stat {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text-muted);
    margin: 0.5rem 0 1rem;
  }

  .platform-col__stat--primary {
    color: var(--color-primary);
  }

  .platform-col__limits,
  .platform-col__benefits {
    list-style: none;
    padding: 0;
    margin: 1.25rem 0 0;
    text-align: left;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    border-top: 1px solid var(--color-border);
    padding-top: 1.25rem;
  }

  .platform-col__limits li {
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--color-text-muted);
    padding-left: 1.5rem;
    position: relative;
  }

  .platform-col__limits li::before {
    content: "\2715";
    position: absolute;
    left: 0;
    color: #ef4444;
    font-weight: 700;
    font-size: 0.75rem;
  }

  .platform-col__benefits li {
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--color-charcoal);
    font-weight: 500;
    padding-left: 1.5rem;
    position: relative;
  }

  .platform-col__benefits li::before {
    content: "\2713";
    position: absolute;
    left: 0;
    color: #22c55e;
    font-weight: 700;
    font-size: 0.85rem;
  }

  /* =============================================
     HOW IT WORKS — Vertical Timeline
     ============================================= */
  .timeline {
    position: relative;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
    padding-left: 60px;
  }

  .timeline__line {
    position: absolute;
    left: 24px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(180deg, var(--color-primary), rgba(255, 82, 82, 0.2));
  }

  .timeline__step {
    position: relative;
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .timeline__step:last-child { margin-bottom: 0; }

  .timeline__marker {
    position: absolute;
    left: -60px;
    top: 0;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--color-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
    flex-shrink: 0;
  }

  .timeline__num {
    font-family: var(--font-heading);
    font-size: 1.2rem;
    font-weight: 700;
    color: white;
  }

  .timeline__card {
    background: var(--color-surface);
    border: 3px double var(--color-border);
    border-radius: var(--radius-lg);
    padding: 2rem;
    flex: 1;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .timeline__card:hover {
    border-color: var(--color-primary);
    box-shadow: 0 4px 20px rgba(255, 82, 82, 0.08);
  }

  /* CTA */
  .feat-cta {
    background: linear-gradient(135deg, var(--color-charcoal), var(--color-dark));
    border-radius: var(--radius-xl); padding: clamp(3rem, 6vw, 5rem); text-align: center;
    position: relative; overflow: hidden;
  }

  .btn-cta-white {
    background: white; color: var(--color-charcoal);
    padding: 1rem 2.5rem; border-radius: var(--radius-full);
    font-weight: 700; font-size: 1rem; text-decoration: none;
    display: inline-flex; align-items: center; gap: 0.5rem;
    transition: all 0.3s var(--ease-smooth); border: none; cursor: pointer;
  }
  .btn-cta-white:hover { transform: translateY(-2px); box-shadow: var(--shadow-lg); }
  .btn-cta-white .arrow { display: inline-block; transition: transform 0.3s var(--ease-smooth); }
  .btn-cta-white:hover .arrow { transform: translateX(4px); }

  /* ============ RESPONSIVE ============ */
  @media (max-width: 900px) {
    .feat-hero__inner { grid-template-columns: 1fr; text-align: center; }
    .feat-hero__content { align-items: center; }

    .film-frames {
      grid-template-columns: repeat(2, 1fr);
    }

    .platforms {
      grid-template-columns: 1fr;
      max-width: 400px;
    }

    .platform-col--highlighted {
      transform: none;
      order: -1;
    }
    .platform-col--highlighted:hover {
      transform: none;
    }
    .platform-col--faded {
      opacity: 1;
    }

    .timeline {
      padding-left: 50px;
    }
    .timeline__line { left: 18px; }
    .timeline__marker { left: -50px; width: 40px; height: 40px; }
  }

  @media (max-width: 600px) {
    .feat-hero { min-height: auto; padding-bottom: 2rem; }
    .video-hero-visual { max-width: 300px; }

    .film-frames {
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }

    .timeline {
      padding-left: 44px;
    }
    .timeline__line { left: 15px; }
    .timeline__marker { left: -44px; width: 34px; height: 34px; }
    .timeline__num { font-size: 1rem; }
    .timeline__card { padding: 1.25rem; }
  }
</style>

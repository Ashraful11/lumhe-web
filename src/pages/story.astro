---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Preloader from '../components/Preloader.astro';
---

<Layout title="Lumhe — The Story of Your Celebration" description="Follow the thread of your celebration journey. From invitation to memories, see how Lumhe brings everything together.">
  <Preloader />
  <Navbar />

  <!-- Scroll progress bar -->
  <div class="scroll-progress" data-scroll-progress></div>

  <div class="story-page">
    <!-- ═══ Hero ═══ -->
    <section class="story-hero">
      <div class="container">
        <div class="story-hero__content">
          <span class="story-label anim-first-hit delay-1">The Celebration Thread</span>
          <h1 class="story-hero__title anim-first-hit delay-2">
            One Thread.<br/>
            <em>Every Moment.</em>
          </h1>
          <p class="story-hero__sub anim-first-hit delay-3">
            Follow the thread of your celebration — from the first invitation to the last shared memory.
          </p>
          <div class="story-hero__scroll-hint anim-first-hit delay-5">
            <div class="scroll-indicator">
              <div class="scroll-indicator__dot"></div>
            </div>
            <span>Scroll to explore</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ Thread Container ═══ -->
    <div class="thread-container">
      <!-- Desktop thread -->
      <svg class="thread-svg thread-svg--desktop" viewBox="0 0 1200 6400" fill="none" preserveAspectRatio="xMidYMin meet" aria-hidden="true">
        <path class="thread-main" d="
          M 600 -50
          C 600 300, 80 200, 80 550
          C 80 900, 1120 700, 1120 1100
          C 1120 1500, 80 1300, 80 1700
          C 80 2100, 1120 1900, 1120 2300
          C 1120 2700, 80 2500, 80 2900
          C 80 3300, 1120 3100, 1120 3500
          C 1120 3900, 80 3700, 80 4100
          C 80 4500, 1120 4300, 1120 4700
          C 1120 5100, 80 4900, 80 5300
          C 80 5700, 600 5600, 600 6000
          L 600 6450
        " stroke="#FF5252" stroke-width="200" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>

      <!-- Mobile thread — centered S-curves, full opacity -->
      <svg class="thread-svg thread-svg--mobile" viewBox="0 0 400 7200" fill="none" preserveAspectRatio="none" aria-hidden="true">
        <path class="thread-main" d="
          M 360 -50
          C 360 80, 240 150, 240 300
          C 240 450, 440 450, 440 600
          C 440 750, 240 750, 240 900
          C 240 1050, 440 1050, 440 1200
          C 440 1350, 240 1350, 240 1500
          C 240 1650, 440 1650, 440 1800
          C 440 1950, 240 1950, 240 2100
          C 240 2250, 440 2250, 440 2400
          C 440 2550, 240 2550, 240 2700
          C 240 2850, 440 2850, 440 3000
          C 440 3150, 240 3150, 240 3300
          C 240 3450, 440 3450, 440 3600
          C 440 3750, 240 3750, 240 3900
          C 240 4050, 440 4050, 440 4200
          C 440 4350, 360 4400, 360 4500
          L 360 7200
        " stroke="#FF5252" stroke-width="70" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>

      <!-- Floating decorations scattered along the thread -->
      <div class="thread-decorations" aria-hidden="true">
        <div class="deco deco--heart" style="top: 5%; left: 25%;">❤️</div>
        <div class="deco deco--star" style="top: 10%; right: 20%;">⭐</div>
        <div class="deco deco--confetti" style="top: 18%; left: 60%;">🎊</div>
        <div class="deco deco--dot" style="top: 22%; left: 12%; background: #FF5252;"></div>
        <div class="deco deco--dot" style="top: 26%; right: 15%; background: #8B5CF6;"></div>
        <div class="deco deco--sparkle" style="top: 30%; left: 45%;">✨</div>
        <div class="deco deco--heart" style="top: 35%; right: 30%;">💕</div>
        <div class="deco deco--dot" style="top: 40%; left: 20%; background: #F59E0B;"></div>
        <div class="deco deco--star" style="top: 44%; right: 10%;">🌟</div>
        <div class="deco deco--confetti" style="top: 48%; left: 70%;">🎉</div>
        <div class="deco deco--dot" style="top: 52%; left: 8%; background: #10B981;"></div>
        <div class="deco deco--sparkle" style="top: 56%; right: 25%;">✨</div>
        <div class="deco deco--heart" style="top: 60%; left: 35%;">❤️</div>
        <div class="deco deco--dot" style="top: 64%; right: 18%; background: #FF5252;"></div>
        <div class="deco deco--star" style="top: 68%; left: 55%;">⭐</div>
        <div class="deco deco--dot" style="top: 72%; left: 15%; background: #8B5CF6;"></div>
        <div class="deco deco--confetti" style="top: 76%; right: 35%;">🎊</div>
        <div class="deco deco--sparkle" style="top: 80%; left: 42%;">✨</div>
        <div class="deco deco--heart" style="top: 84%; right: 12%;">💕</div>
        <div class="deco deco--dot" style="top: 88%; left: 28%; background: #F59E0B;"></div>
        <div class="deco deco--star" style="top: 92%; right: 40%;">🌟</div>
      </div>

      <!-- ═══ Animated Illustrations + Story Nodes ═══ -->

      <!-- Node 1: Upload Invitation -->
      <div class="story-node story-node--1" data-node>
        <div class="story-node__visual">
          <img src="/images/lumhe/invite.png" alt="You're Invited — Lumhe celebration" class="node-img float"/>
        </div>
        <div class="story-node__content">
          <span class="story-label">Step 01</span>
          <h2 class="story-node__title">Upload Your<br/><em>Invitation</em></h2>
          <p class="story-node__desc">Designed on Canva? Shot a video? Got a PDF from the printer? Bring it in any format — image, video, PDF, or text. Your invitation, your way.</p>
        </div>
      </div>

      <!-- Node 2: Add Functions -->
      <div class="story-node story-node--2 story-node--reverse" data-node>
        <div class="story-node__content">
          <span class="story-label">Step 02</span>
          <h2 class="story-node__title">Add Every<br/><em>Function</em></h2>
          <p class="story-node__desc">Haldi, Mehendi, Sangeet, Ceremony, Reception — each with its own date, time, venue, and guest list. One event, multiple functions.</p>
        </div>
        <div class="story-node__visual">
          <div class="illus illus--functions">
            <div class="illus__scene">
              <div class="illus__timeline">
                <div class="tl-item tl-item--anim" style="--delay: 0s; --color: #FFD54F;">
                  <div class="tl-dot"></div>
                  <div class="tl-label">Haldi <span>Dec 10</span></div>
                </div>
                <div class="tl-item tl-item--anim" style="--delay: 0.15s; --color: #CE93D8;">
                  <div class="tl-dot"></div>
                  <div class="tl-label">Mehendi <span>Dec 11</span></div>
                </div>
                <div class="tl-item tl-item--anim" style="--delay: 0.3s; --color: #FF5252;">
                  <div class="tl-dot"></div>
                  <div class="tl-label">Sangeet <span>Dec 11</span></div>
                </div>
                <div class="tl-item tl-item--anim" style="--delay: 0.45s; --color: #64B5F6;">
                  <div class="tl-dot"></div>
                  <div class="tl-label">Ceremony <span>Dec 12</span></div>
                </div>
                <div class="tl-item tl-item--anim" style="--delay: 0.6s; --color: #81C784;">
                  <div class="tl-dot"></div>
                  <div class="tl-label">Reception <span>Dec 12</span></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Node 3: Find & Connect -->
      <div class="story-node story-node--3" data-node>
        <div class="story-node__visual">
          <div class="illus illus--connect">
            <div class="illus__scene">
              <div class="illus__people-web">
                <div class="pw-center">You</div>
                <div class="pw-orbit pw-orbit--1"><div class="pw-person" style="background:#FF8A80;">A</div></div>
                <div class="pw-orbit pw-orbit--2"><div class="pw-person" style="background:#64B5F6;">V</div></div>
                <div class="pw-orbit pw-orbit--3"><div class="pw-person" style="background:#81C784;">M</div></div>
                <div class="pw-orbit pw-orbit--4"><div class="pw-person" style="background:#FFD54F;">R</div></div>
                <div class="pw-orbit pw-orbit--5"><div class="pw-person" style="background:#CE93D8;">P</div></div>
                <div class="pw-orbit pw-orbit--6"><div class="pw-person" style="background:#FF8A65;">S</div></div>
              </div>
              <div class="illus__lines" aria-hidden="true">
                <svg viewBox="0 0 200 200" width="200" height="200">
                  <line x1="100" y1="100" x2="40" y2="30" stroke="var(--color-primary)" stroke-width="1" stroke-opacity="0.15" class="connect-line"/>
                  <line x1="100" y1="100" x2="170" y2="40" stroke="var(--color-primary)" stroke-width="1" stroke-opacity="0.15" class="connect-line"/>
                  <line x1="100" y1="100" x2="30" y2="130" stroke="var(--color-primary)" stroke-width="1" stroke-opacity="0.15" class="connect-line"/>
                  <line x1="100" y1="100" x2="175" y2="150" stroke="var(--color-primary)" stroke-width="1" stroke-opacity="0.15" class="connect-line"/>
                  <line x1="100" y1="100" x2="55" y2="180" stroke="var(--color-primary)" stroke-width="1" stroke-opacity="0.15" class="connect-line"/>
                  <line x1="100" y1="100" x2="155" y2="185" stroke="var(--color-primary)" stroke-width="1" stroke-opacity="0.15" class="connect-line"/>
                </svg>
              </div>
            </div>
          </div>
        </div>
        <div class="story-node__content">
          <span class="story-label">Step 03</span>
          <h2 class="story-node__title">Find &<br/><em>Connect</em></h2>
          <p class="story-node__desc">Search for guests by name, phone, or email right inside Lumhe. Build your celebration circle — your guest list grows with every event. Send invitations directly.</p>
        </div>
      </div>

      <!-- Node 4: Track RSVPs -->
      <div class="story-node story-node--4 story-node--reverse" data-node>
        <div class="story-node__content">
          <span class="story-label">Step 04</span>
          <h2 class="story-node__title">Track Every<br/><em>RSVP</em></h2>
          <p class="story-node__desc">See who confirmed, who hasn't opened, who declined — for each function separately. Send nudge reminders to non-responders only. Real-time headcount.</p>
        </div>
        <div class="story-node__visual">
          <div class="illus illus--rsvp">
            <div class="illus__scene">
              <div class="illus__meter">
                <svg viewBox="0 0 200 200" width="200" height="200">
                  <circle cx="100" cy="100" r="85" fill="none" stroke="var(--color-border)" stroke-width="12"/>
                  <circle cx="100" cy="100" r="85" fill="none" stroke="#10B981" stroke-width="12"
                    stroke-dasharray="534" stroke-dashoffset="134" stroke-linecap="round"
                    transform="rotate(-90 100 100)" class="rsvp-ring"/>
                  <circle cx="100" cy="100" r="85" fill="none" stroke="#F59E0B" stroke-width="12"
                    stroke-dasharray="534" stroke-dashoffset="414" stroke-linecap="round"
                    transform="rotate(180 100 100)" class="rsvp-ring"/>
                </svg>
                <div class="illus__meter-text">
                  <span class="meter-num">84</span>
                  <span class="meter-label">Confirmed</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Node 5: Share -->
      <div class="story-node story-node--5" data-node>
        <div class="story-node__visual">
          <div class="illus illus--share">
            <div class="illus__scene">
              <div class="illus__share-burst">
                <div class="share-ray share-ray--1" style="--angle: -30deg; --color: #25D366;">WhatsApp</div>
                <div class="share-ray share-ray--2" style="--angle: -10deg; --color: #E1306C;">Instagram</div>
                <div class="share-ray share-ray--3" style="--angle: 10deg; --color: #0077B5;">Email</div>
                <div class="share-ray share-ray--4" style="--angle: 30deg; --color: #FF5252;">SMS</div>
                <div class="share-center">
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2">
                    <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
                    <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
                  </svg>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="story-node__content">
          <span class="story-label">Also</span>
          <h2 class="story-node__title">Share<br/><em>Anywhere</em></h2>
          <p class="story-node__desc">Every invite generates a shareable link. Send on WhatsApp, Instagram, email, SMS — no forwarded tag, no missing details. Guests see everything.</p>
        </div>
      </div>

      <!-- Node 6: Moments -->
      <div class="story-node story-node--6 story-node--reverse" data-node>
        <div class="story-node__content">
          <span class="story-label">After the Event</span>
          <h2 class="story-node__title">Collect<br/><em>Moments</em></h2>
          <p class="story-node__desc">A permanent, shared photo timeline. Guests upload their photos — all collected beautifully in one place. Not a WhatsApp group. Organised, permanent, beautiful.</p>
        </div>
        <div class="story-node__visual">
          <div class="moments-collage">
            <img src="/images/lumhe/momets.png" alt="Lumhe Moments — shared celebration photos" class="node-img moments-img--main float"/>
            <img src="/images/lumhe/momets.png" alt="" class="node-img moments-img--bg1 float-r" aria-hidden="true"/>
            <img src="/images/lumhe/momets.png" alt="" class="node-img moments-img--bg2 float" aria-hidden="true"/>
          </div>
        </div>
      </div>

      <!-- Node 7: Digital Lifafa -->
      <div class="story-node story-node--7" data-node>
        <div class="story-node__visual">
          <img src="/images/lumhe/digital_lifafa.png" alt="Digital Lifafa — cashless shagun via UPI" class="node-img float"/>
        </div>
        <div class="story-node__content">
          <span class="story-label">The Gift</span>
          <h2 class="story-node__title">Digital<br/><em>Lifafa</em></h2>
          <p class="story-node__desc">Guests send shagun directly via any UPI app — Lumhe never touches the money. Beautiful animated envelopes, personal messages, instant receipts.</p>
        </div>
      </div>

      <!-- Node 8: Final -->
      <div class="story-node story-node--8 story-node--center" data-node>
        <div class="story-node__content" style="text-align: center; max-width: 640px; margin: 0 auto;">
          <span class="story-label">The Full Picture</span>
          <h2 class="story-node__title" style="font-size: clamp(2.2rem, 4vw, 3.5rem);"><em>One Platform.</em><br/>Every Celebration.</h2>
          <p class="story-node__desc" style="max-width: 500px; margin: 0 auto;">Weddings. Birthdays. Kitty parties. Baby showers. Anniversaries. Housewarming. Farewell. Corporate events. — all free. Always.</p>
          <a href="#" class="btn btn-primary" style="margin-top: 2rem; padding: 1rem 2.5rem; font-size: 1rem;">
            Start Your Celebration — Free
            <span class="arrow">&rarr;</span>
          </a>
        </div>
      </div>
    </div>
  </div>

  <Footer />
</Layout>

<!-- GSAP + ScrollTrigger -->
<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import Lenis from 'lenis';

  gsap.registerPlugin(ScrollTrigger);

  // Only use Lenis on desktop (pointer: fine) — native scroll on touch devices
  const isTouchDevice = window.matchMedia('(hover: none)').matches || window.innerWidth <= 900;
  let lenis: any = null;

  if (isTouchDevice) {
    // Remove lenis classes so native scroll works
    document.documentElement.classList.remove('lenis', 'lenis-smooth');
    document.body.style.overflow = '';
    document.documentElement.style.overflow = '';
  }

  if (!isTouchDevice) {
    lenis = new Lenis({
      duration: 1.2,
      easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
    });
    lenis.on('scroll', ScrollTrigger.update);
    gsap.ticker.add((time) => lenis.raf(time * 1000));
    gsap.ticker.lagSmoothing(0);
  } else {
    // Use native scroll on touch — still update ScrollTrigger
    window.addEventListener('scroll', () => ScrollTrigger.update());
  }

  // ═══ Preloader Animation (MindMarket DrawSVG technique) ═══
  function runPreloader() {
    const preloader = document.querySelector('[data-preloader]') as HTMLElement;
    const preloaderInner = document.querySelector('[data-preloader-inner]') as HTMLElement;
    const preloaderSvg = document.querySelector('[data-preloader-svg]') as SVGElement;
    const mainPath = document.querySelector('[data-main-path]') as SVGPathElement;
    const innerPath = document.querySelector('[data-inner-path]') as SVGPathElement;
    const dot = document.querySelector('[data-dot]') as SVGCircleElement;
    const shadow1 = document.querySelector('.preloader__shadow--1') as SVGPathElement;
    const shadow2 = document.querySelector('.preloader__shadow--2') as SVGPathElement;
    const sparkles = document.querySelectorAll('.preloader__sparkle');
    const preloaderText = document.querySelector('[data-preloader-text]') as HTMLElement;

    if (!preloader || !mainPath) { init(); return; }

    // Fallback: if preloader doesn't complete in 5s, force it done
    setTimeout(() => {
      if (!preloader.classList.contains('is-done')) {
        preloader.classList.add('is-done');
        if (lenis) lenis.start();
        document.documentElement.classList.add('is-first-loaded');
        init();
      }
    }, 5000);

    // Calculate path lengths for draw animation
    const mainLen = mainPath.getTotalLength();
    const innerLen = innerPath.getTotalLength();
    mainPath.style.strokeDasharray = `${mainLen}`;
    mainPath.style.strokeDashoffset = `${mainLen}`;
    innerPath.style.strokeDasharray = `${innerLen}`;
    innerPath.style.strokeDashoffset = `${innerLen}`;

    // Lock scroll during preloader
    if (lenis) lenis.stop();

    // Build GSAP timeline — mirrors MindMarket's Preloader.js structure
    const tl = gsap.timeline({
      paused: false,
      onComplete: () => {
        preloader.classList.add('is-done');
        if (lenis) lenis.start();
        document.documentElement.classList.add('is-first-loaded');
        init();
      },
    });

    tl
      // 1. Fade in the wrapper
      .set(preloaderInner, { opacity: 1 })
      .addLabel('start')

      // 2. Slide SVG in from below (MindMarket: y 15% → 0%)
      .fromTo(preloaderSvg,
        { y: '20%', opacity: 0 },
        { y: '0%', opacity: 1, ease: 'power2.inOut', duration: 0.8 }
      )

      // 3. Draw main heart path (0% → 100%) — the core DrawSVG technique
      .to(mainPath,
        { strokeDashoffset: 0, ease: 'power1.inOut', duration: 1.2 },
        'start'
      )

      // 4. Reveal shadow paths with staggered timing (MindMarket: start+=0.39, start+=0.58)
      .fromTo(shadow1,
        { opacity: 0 },
        { opacity: 1, ease: 'none', duration: 0.3 },
        'start+=0.45'
      )
      .fromTo(shadow2,
        { opacity: 0 },
        { opacity: 1, ease: 'none', duration: 0.3 },
        'start+=0.65'
      )

      // 5. Draw inner decorative path
      .to(innerPath,
        { strokeDashoffset: 0, ease: 'power1.inOut', duration: 0.8 },
        'start+=0.4'
      )

      // 6. Scale dot with elastic easing (MindMarket: elastic.out(1, 0.3))
      .to(dot,
        { scaleY: 1, scaleX: 1, ease: 'elastic.out(1, 0.3)', duration: 1 },
        '-=0.4'
      )

      // 7. Pop in sparkles
      .to(sparkles,
        { opacity: 1, scale: 1, ease: 'back.out(3)', duration: 0.4, stagger: 0.1 },
        '-=0.6'
      )

      // 8. Fade in brand text
      .to(preloaderText,
        { opacity: 1, y: 0, ease: 'power2.out', duration: 0.5 },
        '-=0.5'
      )

      // 9. Hold for a moment, then slide everything up and out (MindMarket: y 0% → -15%)
      .to({}, { duration: 0.3 })
      .to(preloaderInner,
        { y: '-20%', opacity: 0, ease: 'power2.inOut', duration: 0.6 }
      );
  }

  function init() {
    // ── Thread drawing — all 4 layers locked to scroll ──
    // Initialize only the visible thread (desktop or mobile)
    const visibleSvg = isTouchDevice
      ? document.querySelector('.thread-svg--mobile')
      : document.querySelector('.thread-svg--desktop');
    const threadPath = visibleSvg?.querySelector('.thread-main') as SVGPathElement | null;

    if (threadPath) {
      const length = threadPath.getTotalLength();
      threadPath.style.strokeDasharray = `${length}`;
      threadPath.style.strokeDashoffset = `${length}`;
    }

    if (!threadPath) { /* no thread to animate */ }
    else gsap.to(threadPath, {
      strokeDashoffset: 0,
      ease: 'none',
      scrollTrigger: {
        trigger: '.thread-container',
        start: 'top top',
        end: 'bottom bottom',
        scrub: 1.5,
      },
    });

    // ── Story nodes — entrance animations ──
    document.querySelectorAll<HTMLElement>('[data-node]').forEach((node) => {
      const visual = node.querySelector('.story-node__visual') as HTMLElement;
      const content = node.querySelector('.story-node__content') as HTMLElement;
      const isReverse = node.classList.contains('story-node--reverse');
      const isCenter = node.classList.contains('story-node--center');

      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: node,
          start: isTouchDevice ? 'top 85%' : 'top 80%',
          end: isTouchDevice ? 'top 60%' : 'top 35%',
          scrub: isTouchDevice ? false : 1,
          toggleActions: isTouchDevice ? 'play none none none' : undefined,
        },
      });

      if (isCenter) {
        tl.from(content, { opacity: 0, y: 60, scale: 0.95, duration: 0.8, ease: 'power3.out' });
      } else {
        tl.from(visual, { opacity: 0, y: isTouchDevice ? 40 : 0, x: isTouchDevice ? 0 : (isReverse ? 100 : -100), scale: 0.9, duration: 0.8, ease: 'power3.out' }, 0);
        tl.from(content, { opacity: 0, y: 40, duration: 0.8, ease: 'power3.out' }, 0.15);
      }
    });

    // ── Illustration trigger animations ──
    // Timeline items cascade when node enters
    document.querySelectorAll('.tl-item--anim').forEach((item) => {
      const el = item as HTMLElement;
      const delay = parseFloat(getComputedStyle(el).getPropertyValue('--delay')) || 0;
      gsap.from(el, {
        opacity: 0, x: -30, duration: 0.5, delay,
        scrollTrigger: { trigger: el.closest('[data-node]')!, start: 'top 70%' }
      });
    });

    // Connect lines draw
    document.querySelectorAll('.connect-line').forEach((line, i) => {
      const el = line as SVGLineElement;
      const len = Math.sqrt(Math.pow(Number(el.getAttribute('x2')) - Number(el.getAttribute('x1')), 2) + Math.pow(Number(el.getAttribute('y2')) - Number(el.getAttribute('y1')), 2));
      el.style.strokeDasharray = `${len}`;
      el.style.strokeDashoffset = `${len}`;
      gsap.to(el, {
        strokeDashoffset: 0, duration: 0.6, delay: i * 0.1,
        scrollTrigger: { trigger: el.closest('[data-node]')!, start: 'top 65%' }
      });
    });

    // RSVP ring fill
    document.querySelectorAll('.rsvp-ring').forEach((ring) => {
      const el = ring as SVGCircleElement;
      const target = el.getAttribute('stroke-dashoffset') || '0';
      el.style.strokeDashoffset = '534';
      gsap.to(el, {
        strokeDashoffset: target, duration: 1.5, ease: 'power2.out',
        scrollTrigger: { trigger: el.closest('[data-node]')!, start: 'top 65%' }
      });
    });

    // ── First-hit hero ──
    setTimeout(() => {
      document.querySelectorAll('.anim-first-hit').forEach((el) => {
        if (el.getBoundingClientRect().top < window.innerHeight) el.classList.add('is-visible');
      });
    }, 100);

    // ── Scroll Progress Bar ──
    const progressBar = document.querySelector<HTMLElement>('[data-scroll-progress]');
    function updateProgress() {
      if (!progressBar) return;
      const scrollTop = window.scrollY;
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      const progress = (scrollTop / docHeight) * 100;
      progressBar.style.width = `${progress}%`;
    }
    if (lenis) { lenis.on('scroll', updateProgress); }
    else { window.addEventListener('scroll', updateProgress, { passive: true }); }

    // ── Floating Decorations — reveal on scroll ──
    const decoObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            // Stagger the reveal with a random delay for organic feel
            const delay = Math.random() * 300;
            setTimeout(() => entry.target.classList.add('is-visible'), delay);
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px 100px 0px' }
    );
    document.querySelectorAll('.deco').forEach((el) => decoObserver.observe(el));

    // ── Navbar ──
    const nav = document.querySelector<HTMLElement>('.navbar');
    if (nav) {
      let lastScroll = 0;
      function updateNav() {
        const s = window.scrollY;
        nav!.classList.toggle('navbar--scrolled', s > 80);
        nav!.classList.toggle('navbar--hidden', s > lastScroll && s > 400);
        lastScroll = s;
      }
      if (lenis) { lenis.on('scroll', updateNav); }
      else { window.addEventListener('scroll', updateNav, { passive: true }); }
    }

    // Fallback: ensure all node content is visible after 4s even if GSAP scrub hasn't triggered
    setTimeout(() => {
      document.querySelectorAll('[data-node] .story-node__visual, [data-node] .story-node__content').forEach((el) => {
        const htmlEl = el as HTMLElement;
        if (parseFloat(getComputedStyle(htmlEl).opacity) < 0.5) {
          gsap.to(htmlEl, { opacity: 1, x: 0, y: 0, scale: 1, rotation: 0, duration: 0.6, ease: 'power2.out' });
        }
      });
    }, 4000);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', runPreloader);
  } else {
    runPreloader();
  }
</script>


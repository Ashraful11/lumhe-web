---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar.astro';
import Footer from '../../../components/Footer.astro';

import type { CountryCode } from '../../../data/countries';

export function getStaticPaths() {
  return [{ params: { country: 'in' } }];
}
const country = Astro.params.country as CountryCode;
---

<Layout title="Lifafa Tips — Make Digital Shagun Special" description="Tips for sending meaningful digital shagun. Choose the right amount, add personal messages, and master digital gifting etiquette for Indian celebrations.">
  <Navbar country={country} />

  <!-- Hero -->
  <section class="feat-hero">
    <div class="container">
      <div class="feat-hero__inner">
        <div class="feat-hero__content">
          <div class="anim-first-hit delay-1">
            <span class="feat-badge">Lifafa Tips</span>
          </div>
          <h1 class="heading-2xl anim-first-hit delay-2">
            Make Digital Shagun<br/>
            <em>Feel Special</em>
          </h1>
          <p class="body-lg text-muted anim-first-hit delay-3" style="max-width: 520px;">
            Going digital doesn't mean losing the personal touch. Here's how to send shagun that feels as warm and meaningful as handing over a lifafa in person.
          </p>
          <div class="feat-hero__cta anim-first-hit delay-4">
            <a href="#" class="btn btn-primary magnetic">Send Digital Lifafa — Free <span class="arrow">&rarr;</span></a>
          </div>
        </div>
        <div class="feat-hero__visual anim-first-hit delay-3">
          <img src="/images/lumhe/digital_lifafa.png" alt="Tips for sending digital shagun" class="feat-hero__img"/>
        </div>
      </div>
    </div>
  </section>

  <!-- What is Lifafa: Envelope Reveal -->
  <section class="section bg-surface-alt">
    <div class="container">
      <div class="text-center reveal" style="max-width: 600px; margin: 0 auto;">
        <span class="label text-primary">Tradition Meets Digital</span>
        <h2 class="heading-xl" style="margin-top: 0.5rem;">
          What Is a<br/><em class="font-serif">Lifafa / Shagun?</em>
        </h2>
      </div>

      <div class="envelope-section reveal" style="margin-top: var(--space-2xl);">
        <div class="envelope-shape">
          <div class="envelope-flap"></div>
          <div class="envelope-body">
            <p class="body-lg" style="color: var(--color-charcoal); max-width: 480px; margin: 0 auto; line-height: 1.7;">
              In Indian culture, a <strong>lifafa</strong> (envelope) carrying <strong>shagun</strong> (auspicious gift of money) is a deeply personal gesture. It symbolises blessings, love, and good wishes for the host and their family.
            </p>
            <p class="body-md" style="margin-top: 1rem; color: var(--color-text-muted); max-width: 440px; margin-left: auto; margin-right: auto;">
              Digital Lifafa on Lumhe preserves this beautiful tradition — just without the physical envelope. Same warmth, modern convenience.
            </p>
          </div>
        </div>

        <div class="ticker-wrap" style="margin-top: var(--space-xl);">
          <div class="ticker stagger-children">
            <div class="ticker__track">
              <span class="ticker__pill">
                <span class="ticker__pill-num">98%</span>
                <span class="ticker__pill-label">of Indian celebrations include shagun</span>
              </span>
              <span class="ticker__pill">
                <span class="ticker__pill-num">3x</span>
                <span class="ticker__pill-label">yearly growth in digital shagun</span>
              </span>
              <span class="ticker__pill">
                <span class="ticker__pill-num">Instant</span>
                <span class="ticker__pill-label">delivery with Lumhe Digital Lifafa</span>
              </span>
              <!-- Duplicate for seamless loop -->
              <span class="ticker__pill" aria-hidden="true">
                <span class="ticker__pill-num">98%</span>
                <span class="ticker__pill-label">of Indian celebrations include shagun</span>
              </span>
              <span class="ticker__pill" aria-hidden="true">
                <span class="ticker__pill-num">3x</span>
                <span class="ticker__pill-label">yearly growth in digital shagun</span>
              </span>
              <span class="ticker__pill" aria-hidden="true">
                <span class="ticker__pill-num">Instant</span>
                <span class="ticker__pill-label">delivery with Lumhe Digital Lifafa</span>
              </span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Amount Guide: Table -->
  <section class="section">
    <div class="container">
      <div class="text-center reveal" style="max-width: 600px; margin: 0 auto;">
        <span class="label text-primary">Amount Guide</span>
        <h2 class="heading-xl" style="margin-top: 0.5rem;">
          Suggested Amounts by<br/><em class="font-serif">Occasion & Relationship</em>
        </h2>
        <p class="body-lg text-muted" style="margin-top: 1rem;">
          There's no fixed rule — the best amount is what comes from the heart. Here are common norms to help you decide.
        </p>
      </div>

      <div class="table-wrap reveal" style="margin-top: var(--space-2xl);">
        <table class="amount-table">
          <thead>
            <tr>
              <th class="amount-table__occasion">Occasion</th>
              <th class="amount-table__highlight">Close Family</th>
              <th>Extended Family</th>
              <th>Friends</th>
              <th>Colleagues</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="amount-table__occasion-cell">&#128146; Wedding</td>
              <td class="amount-table__highlight-cell">&#8377;5,001 &ndash; &#8377;21,001</td>
              <td>&#8377;2,101 &ndash; &#8377;5,001</td>
              <td>&#8377;1,001 &ndash; &#8377;3,001</td>
              <td>&#8377;501 &ndash; &#8377;2,001</td>
            </tr>
            <tr>
              <td class="amount-table__occasion-cell">&#127874; Birthday</td>
              <td class="amount-table__highlight-cell">&#8377;1,001 &ndash; &#8377;5,001</td>
              <td>&#8377;501 &ndash; &#8377;1,001</td>
              <td>&#8377;251 &ndash; &#8377;1,001</td>
              <td>&#8377;251 &ndash; &#8377;501</td>
            </tr>
            <tr>
              <td class="amount-table__occasion-cell">&#128141; Anniversary</td>
              <td class="amount-table__highlight-cell">&#8377;2,001 &ndash; &#8377;11,001</td>
              <td>&#8377;1,001 &ndash; &#8377;3,001</td>
              <td>&#8377;501 &ndash; &#8377;2,001</td>
              <td>&#8377;501 &ndash; &#8377;1,001</td>
            </tr>
            <tr>
              <td class="amount-table__occasion-cell">&#128118; Baby Shower</td>
              <td class="amount-table__highlight-cell">&#8377;2,001 &ndash; &#8377;5,001</td>
              <td>&#8377;1,001 &ndash; &#8377;2,001</td>
              <td>&#8377;501 &ndash; &#8377;1,001</td>
              <td>&#8377;501 &ndash; &#8377;1,001</td>
            </tr>
            <tr>
              <td class="amount-table__occasion-cell">&#127968; Housewarming</td>
              <td class="amount-table__highlight-cell">&#8377;2,001 &ndash; &#8377;11,001</td>
              <td>&#8377;1,001 &ndash; &#8377;2,101</td>
              <td>&#8377;501 &ndash; &#8377;1,101</td>
              <td>&#8377;501 &ndash; &#8377;1,001</td>
            </tr>
            <tr>
              <td class="amount-table__occasion-cell">&#128588; Farewell</td>
              <td class="amount-table__highlight-cell">&#8377;1,001 &ndash; &#8377;2,001</td>
              <td>&#8377;501 &ndash; &#8377;1,001</td>
              <td>&#8377;301 &ndash; &#8377;1,001</td>
              <td>&#8377;251 &ndash; &#8377;501</td>
            </tr>
          </tbody>
        </table>
      </div>

      <p class="body-sm text-muted text-center" style="margin-top: 1rem; opacity: 0.7;">
        Tip: Odd numbers ending in 1 (like &#8377;501, &#8377;1,001, &#8377;2,101) are traditionally considered auspicious.
      </p>
    </div>
  </section>

  <!-- Do's and Don'ts -->
  <section class="section bg-surface-alt">
    <div class="container">
      <div class="text-center reveal" style="max-width: 600px; margin: 0 auto;">
        <span class="label text-primary">Etiquette</span>
        <h2 class="heading-xl" style="margin-top: 0.5rem;">
          Digital Shagun<br/><em class="font-serif">Do's & Don'ts</em>
        </h2>
      </div>

      <div class="flip-grid stagger-children" style="margin-top: var(--space-2xl);">
        <div class="flip-card">
          <div class="flip-card__inner">
            <div class="flip-card__front">
              <span class="flip-card__badge flip-card__badge--do">Do</span>
              <p class="body-md">Send on time — ideally on the day of the event or the day before</p>
              <span class="flip-card__hint">Hover to see the don't</span>
            </div>
            <div class="flip-card__back">
              <span class="flip-card__badge flip-card__badge--dont">Don't</span>
              <p class="body-md">Don't delay the gift — a late shagun feels like an afterthought</p>
            </div>
          </div>
        </div>
        <div class="flip-card">
          <div class="flip-card__inner">
            <div class="flip-card__front">
              <span class="flip-card__badge flip-card__badge--do">Do</span>
              <p class="body-md">Add a personal message — mention a memory, a wish, or something heartfelt</p>
              <span class="flip-card__hint">Hover to see the don't</span>
            </div>
            <div class="flip-card__back">
              <span class="flip-card__badge flip-card__badge--dont">Don't</span>
              <p class="body-md">Don't skip the message — a plain transfer feels cold and transactional</p>
            </div>
          </div>
        </div>
        <div class="flip-card">
          <div class="flip-card__inner">
            <div class="flip-card__front">
              <span class="flip-card__badge flip-card__badge--do">Do</span>
              <p class="body-md">Use auspicious amounts ending in 1 — like &#8377;501, &#8377;1,001, &#8377;2,101</p>
              <span class="flip-card__hint">Hover to see the don't</span>
            </div>
            <div class="flip-card__back">
              <span class="flip-card__badge flip-card__badge--dont">Don't</span>
              <p class="body-md">Don't send round numbers (500, 1000) — they're considered inauspicious</p>
            </div>
          </div>
        </div>
        <div class="flip-card">
          <div class="flip-card__inner">
            <div class="flip-card__front">
              <span class="flip-card__badge flip-card__badge--do">Do</span>
              <p class="body-md">Include a voice note for an extra personal touch that text can't match</p>
              <span class="flip-card__hint">Hover to see the don't</span>
            </div>
            <div class="flip-card__back">
              <span class="flip-card__badge flip-card__badge--dont">Don't</span>
              <p class="body-md">Don't forget to check your receipt — confirm the gift was delivered</p>
            </div>
          </div>
        </div>
        <div class="flip-card">
          <div class="flip-card__inner">
            <div class="flip-card__front">
              <span class="flip-card__badge flip-card__badge--do">Do</span>
              <p class="body-md">Thank the host for including you in their celebration</p>
              <span class="flip-card__hint">Hover to see the don't</span>
            </div>
            <div class="flip-card__back">
              <span class="flip-card__badge flip-card__badge--dont">Don't</span>
              <p class="body-md">Don't share the amount publicly — it's between you and the host</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section" style="padding-bottom: var(--space-3xl);">
    <div class="container">
      <div class="feat-cta reveal-scale">
        <h2 class="heading-xl" style="color: white;">
          Ready to Send<br/><em class="font-serif">Meaningful Shagun?</em>
        </h2>
        <p class="body-lg" style="margin-top: 1rem; color: rgba(255,255,255,0.8); max-width: 480px; margin-left: auto; margin-right: auto;">
          Pick an envelope. Write your message. Send via UPI. It's that simple — and completely free.
        </p>
        <a href="#" class="btn btn-cta-white" style="margin-top: var(--space-lg);">
          Send Digital Lifafa — Free <span class="arrow">&rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <Footer country={country} />
</Layout>

<style>
  @import '../../../styles/global.css';

  .feat-hero {
    min-height: 90vh;
    display: flex;
    align-items: center;
    padding: var(--space-3xl) 0;
    padding-top: calc(var(--space-3xl) + 80px);
    background: linear-gradient(180deg, var(--color-surface-warm) 0%, var(--color-surface) 60%);
  }

  .feat-hero__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-2xl);
    align-items: center;
  }

  .feat-hero__content { display: flex; flex-direction: column; gap: var(--space-md); }

  .feat-badge {
    font-family: var(--font-body); font-size: 0.7rem; font-weight: 700;
    letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-primary);
    background: rgba(255,82,82,0.06); padding: 0.4rem 1.2rem; border-radius: var(--radius-full);
    display: inline-block;
  }

  .feat-hero__content h1 { color: var(--color-charcoal); }
  .feat-hero__content h1 em { color: var(--color-primary); font-style: italic; }

  .feat-hero__cta { margin-top: var(--space-sm); }

  .feat-hero__img {
    width: 100%; max-width: 440px; border-radius: var(--radius-xl);
    box-shadow: var(--shadow-lg); margin: 0 auto; display: block;
  }

  /* ===== ENVELOPE SHAPE ===== */
  .envelope-section {
    max-width: 640px;
    margin-left: auto;
    margin-right: auto;
  }

  .envelope-shape {
    position: relative;
    background: var(--color-secondary);
    border-radius: 0 0 var(--radius-xl) var(--radius-xl);
    padding: 3rem 2.5rem 2.5rem;
    text-align: center;
    clip-path: polygon(0 14%, 50% 0%, 100% 14%, 100% 100%, 0 100%);
  }

  .envelope-flap {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  .envelope-body {
    position: relative;
    z-index: 1;
    padding-top: 1rem;
  }

  /* ===== TICKER TAPE ===== */
  .ticker-wrap {
    overflow: hidden;
    border-radius: var(--radius-xl);
    background: var(--color-charcoal);
    padding: 0;
  }

  .ticker {
    overflow: hidden;
  }

  .ticker__track {
    display: flex;
    gap: 2rem;
    width: max-content;
    animation: tickerScroll 18s linear infinite;
  }

  @keyframes tickerScroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  .ticker__pill {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1.25rem 2rem;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .ticker__pill-num {
    font-family: var(--font-heading);
    font-size: 2.25rem;
    font-weight: 800;
    color: var(--color-primary);
    line-height: 1;
  }

  .ticker__pill-label {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.7);
    max-width: 180px;
    white-space: normal;
    line-height: 1.3;
  }

  /* ===== AMOUNT TABLE ===== */
  .table-wrap {
    max-width: 900px;
    margin-left: auto;
    margin-right: auto;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .amount-table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    border-radius: var(--radius-xl);
    overflow: hidden;
    border: 1px solid var(--color-border);
    font-size: 0.88rem;
  }

  .amount-table thead th {
    padding: 1rem 1.25rem;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    background: var(--color-surface);
    border-bottom: 2px solid var(--color-border);
    text-align: center;
    white-space: nowrap;
  }

  .amount-table thead th.amount-table__highlight {
    background: var(--color-primary);
    color: white;
  }

  .amount-table tbody td {
    padding: 0.9rem 1.25rem;
    text-align: center;
    color: var(--color-charcoal);
    font-weight: 500;
    white-space: nowrap;
  }

  .amount-table tbody tr:nth-child(odd) td {
    background: var(--color-surface);
  }

  .amount-table tbody tr:nth-child(even) td {
    background: var(--color-surface-alt);
  }

  .amount-table__occasion-cell {
    text-align: left !important;
    font-weight: 600 !important;
  }

  .amount-table__highlight-cell {
    background: rgba(255, 82, 82, 0.04) !important;
    font-weight: 700 !important;
    color: var(--color-primary) !important;
  }

  .amount-table__occasion {
    text-align: left !important;
  }

  /* ===== FLIP CARD LAYOUT ===== */
  .flip-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1rem;
    max-width: 1000px;
    margin-left: auto;
    margin-right: auto;
  }

  .flip-card {
    perspective: 800px;
    min-height: 240px;
  }

  .flip-card__inner {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: 240px;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    transform-style: preserve-3d;
  }

  .flip-card:hover .flip-card__inner {
    transform: rotateY(180deg);
  }

  .flip-card__front,
  .flip-card__back {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .flip-card__front {
    background: linear-gradient(160deg, #E8F5E9, #C8E6C9);
    border: 1px solid rgba(76, 175, 80, 0.2);
  }

  .flip-card__front p {
    color: var(--color-charcoal);
    line-height: 1.5;
    font-size: 0.88rem;
  }

  .flip-card__back {
    background: linear-gradient(160deg, #FFEBEE, #FFCDD2);
    border: 1px solid rgba(255, 82, 82, 0.2);
    transform: rotateY(180deg);
  }

  .flip-card__back p {
    color: var(--color-charcoal);
    line-height: 1.5;
    font-size: 0.88rem;
  }

  .flip-card__badge {
    display: inline-block;
    width: fit-content;
    padding: 0.25rem 0.75rem;
    border-radius: var(--radius-full);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .flip-card__badge--do {
    background: #4CAF50;
    color: white;
  }

  .flip-card__badge--dont {
    background: var(--color-primary);
    color: white;
  }

  .flip-card__hint {
    margin-top: auto;
    font-size: 0.68rem;
    color: rgba(0,0,0,0.3);
    font-style: italic;
  }

  /* ===== CTA ===== */
  .feat-cta {
    background: linear-gradient(135deg, var(--color-charcoal), var(--color-dark));
    border-radius: var(--radius-xl); padding: clamp(3rem, 6vw, 5rem); text-align: center;
    position: relative; overflow: hidden;
  }

  .btn-cta-white {
    background: white; color: var(--color-charcoal);
    padding: 1rem 2.5rem; border-radius: var(--radius-full);
    font-weight: 700; font-size: 1rem; text-decoration: none;
    display: inline-flex; align-items: center; gap: 0.5rem;
    transition: all 0.3s ease; border: none; cursor: pointer;
  }
  .btn-cta-white:hover { transform: translateY(-2px); box-shadow: var(--shadow-lg); }
  .btn-cta-white .arrow { display: inline-block; transition: transform 0.3s ease; }
  .btn-cta-white:hover .arrow { transform: translateX(4px); }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 900px) {
    .feat-hero__inner { grid-template-columns: 1fr; text-align: center; }
    .feat-hero__content { align-items: center; }

    .flip-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 600px) {
    .feat-hero { min-height: auto; padding-bottom: 2rem; }
    .feat-hero__img { max-width: 300px; }

    .envelope-shape {
      padding: 2.5rem 1.5rem 2rem;
      clip-path: polygon(0 10%, 50% 0%, 100% 10%, 100% 100%, 0 100%);
    }

    .ticker__pill-num { font-size: 1.75rem; }
    .ticker__pill { padding: 1rem 1.5rem; }

    .flip-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .flip-card__inner { min-height: 200px; }

    /* On mobile, show both sides stacked instead of flip */
    .flip-card:active .flip-card__inner {
      transform: rotateY(180deg);
    }

    .amount-table {
      font-size: 0.78rem;
    }

    .amount-table thead th,
    .amount-table tbody td {
      padding: 0.7rem 0.75rem;
    }

    .flip-card__hint { display: none; }
  }
</style>

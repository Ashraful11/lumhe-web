---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar.astro';
import Footer from '../../../components/Footer.astro';

import type { CountryCode } from '../../../data/countries';

export function getStaticPaths() {
  return [{ params: { country: 'in' } }, { params: { country: 'us' } }, { params: { country: 'uk' } }];
}
const country = Astro.params.country as CountryCode;
---

<Layout title="Event Photography Tips — Lumhe Moments" description="Capture stunning celebration photos with these practical tips. Collect every guest's photos in one permanent timeline with Lumhe Moments — free, no app downloads, no expiry.">
  <Navbar country={country} />

  <!-- Hero -->
  <section class="feat-hero">
    <div class="container">
      <div class="feat-hero__inner">
        <div class="feat-hero__content">
          <div class="anim-first-hit delay-1">
            <span class="feat-badge">Moments</span>
          </div>
          <h1 class="heading-2xl anim-first-hit delay-2">
            Event Photography<br/>
            <em>Tips That Work</em>
          </h1>
          <p class="body-lg text-muted anim-first-hit delay-3" style="max-width: 520px;">
            Great celebration photos don't need a professional camera. Learn simple tips to capture unforgettable moments — then collect every guest's photos in one place with Lumhe Moments.
          </p>
          <div class="feat-hero__cta anim-first-hit delay-4">
            <a href="#" class="btn btn-primary magnetic">Try Lumhe Moments — Free <span class="arrow">&rarr;</span></a>
          </div>
        </div>
        <div class="feat-hero__visual anim-first-hit delay-3">
          <img src="/images/lumhe/momets.png" alt="Lumhe Moments — event photo collection" class="feat-hero__img"/>
        </div>
      </div>
    </div>
  </section>

  <!-- Photo Mosaic Grid -->
  <section class="section bg-surface-alt">
    <div class="container">
      <div class="text-center reveal" style="max-width: 600px; margin: 0 auto;">
        <span class="label text-primary">Photography Tips</span>
        <h2 class="heading-xl" style="margin-top: 0.5rem;">
          Simple Tips for<br/><em class="font-serif">Stunning Photos</em>
        </h2>
        <p class="body-lg text-muted" style="margin-top: 1rem;">
          Hover over each photo to reveal the tip. No expensive gear needed — just your smartphone.
        </p>
      </div>

      <div class="editorial stagger-children" style="margin-top: var(--space-2xl);">
        <!-- Tip 1: Pull-quote style -->
        <article class="editorial__block editorial__block--pullquote reveal">
          <div class="editorial__quote-marks">&ldquo;</div>
          <h3 class="heading-lg">Rule of Thirds</h3>
          <p class="body-lg" style="max-width: 640px;">Place your subject off-center using the grid lines. It creates a more natural, dynamic composition that draws the eye exactly where you want it.</p>
          <span class="editorial__tip-num">Tip 01</span>
        </article>

        <!-- Tip 2 & 3: Two-column split -->
        <div class="editorial__split reveal">
          <article class="editorial__block editorial__block--sidebar">
            <span class="editorial__sidebar-num">02</span>
            <div class="editorial__sidebar-content">
              <h3 class="heading-md">Golden Hour Lighting</h3>
              <p class="body-md text-muted">Shoot during the hour after sunrise or before sunset. The warm, soft light flatters every skin tone and adds magic to any scene.</p>
            </div>
          </article>
          <article class="editorial__block editorial__block--sidebar">
            <span class="editorial__sidebar-num">03</span>
            <div class="editorial__sidebar-content">
              <h3 class="heading-md">Candid Over Posed</h3>
              <p class="body-md text-muted">Real laughter beats forced smiles. Stay alert and shoot freely — the best moments are unscripted.</p>
            </div>
          </article>
        </div>

        <!-- Tip 4: Indented blockquote with accent line -->
        <article class="editorial__block editorial__block--blockquote reveal">
          <div class="editorial__accent-line"></div>
          <div class="editorial__blockquote-body">
            <span class="editorial__blockquote-num">04</span>
            <h3 class="heading-md">Capture Details</h3>
            <p class="body-lg text-muted">Flowers, table settings, the invitation — details set the mood and tell the full story of your event.</p>
          </div>
        </article>

        <!-- Tip 5: Full-width banner -->
        <article class="editorial__block editorial__block--banner reveal">
          <div class="editorial__banner-inner">
            <span class="editorial__banner-num">05</span>
            <div class="editorial__banner-text">
              <h3 class="heading-lg">Nail Group Shots</h3>
              <p class="body-md">Get everyone's attention first. Take 3-4 shots quickly — at least one will have everyone looking and smiling naturally.</p>
            </div>
          </div>
        </article>

        <!-- Tip 6: Marginal note style -->
        <article class="editorial__block editorial__block--marginal reveal">
          <div class="editorial__marginal-aside">
            <span class="editorial__marginal-label">Tip</span>
            <span class="editorial__marginal-num">06</span>
          </div>
          <div class="editorial__marginal-body">
            <h3 class="heading-lg">Master Indoor Lighting</h3>
            <p class="body-lg text-muted" style="max-width: 560px;">Face your subject towards windows or bright areas. Avoid flash — it flattens faces and kills the event ambience completely.</p>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- Why Lumhe Moments: Comparison -->
  <section class="section">
    <div class="container">
      <div class="text-center reveal" style="max-width: 600px; margin: 0 auto;">
        <span class="label text-primary">Why Lumhe Moments?</span>
        <h2 class="heading-xl" style="margin-top: 0.5rem;">
          WhatsApp Groups vs<br/><em class="font-serif">Lumhe Moments</em>
        </h2>
        <p class="body-lg text-muted" style="margin-top: 1rem;">
          Great photos deserve better than a chaotic chat thread.
        </p>
      </div>

      <div class="comparison reveal" style="margin-top: var(--space-2xl);">
        <div class="comparison__side comparison__side--whatsapp">
          <div class="comparison__header comparison__header--whatsapp">
            <span class="comparison__icon">&#128172;</span>
            <h3 class="heading-md">WhatsApp Groups</h3>
          </div>
          <ul class="comparison__list">
            <li class="comparison__item comparison__item--negative">
              <span class="comparison__mark comparison__mark--x">&#10005;</span>
              <span>Photos expire in Stories</span>
            </li>
            <li class="comparison__item comparison__item--negative">
              <span class="comparison__mark comparison__mark--x">&#10005;</span>
              <span>Lost in group chats</span>
            </li>
            <li class="comparison__item comparison__item--negative">
              <span class="comparison__mark comparison__mark--x">&#10005;</span>
              <span>Compressed quality</span>
            </li>
            <li class="comparison__item comparison__item--negative">
              <span class="comparison__mark comparison__mark--x">&#10005;</span>
              <span>No organization</span>
            </li>
          </ul>
        </div>

        <div class="comparison__divider">
          <span class="comparison__vs">VS</span>
        </div>

        <div class="comparison__side comparison__side--lumhe">
          <div class="comparison__header comparison__header--lumhe">
            <span class="comparison__icon">&#10024;</span>
            <h3 class="heading-md">Lumhe Moments</h3>
          </div>
          <ul class="comparison__list">
            <li class="comparison__item comparison__item--positive">
              <span class="comparison__mark comparison__mark--check">&#10003;</span>
              <span>Permanent album</span>
            </li>
            <li class="comparison__item comparison__item--positive">
              <span class="comparison__mark comparison__mark--check">&#10003;</span>
              <span>All photos in one place</span>
            </li>
            <li class="comparison__item comparison__item--positive">
              <span class="comparison__mark comparison__mark--check">&#10003;</span>
              <span>Original quality</span>
            </li>
            <li class="comparison__item comparison__item--positive">
              <span class="comparison__mark comparison__mark--check">&#10003;</span>
              <span>Organized by event</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Tips Carousel -->
  <section class="section bg-surface-alt">
    <div class="container">
      <div class="text-center reveal" style="max-width: 600px; margin: 0 auto;">
        <span class="label text-primary">Quick Reference</span>
        <h2 class="heading-xl" style="margin-top: 0.5rem;">
          Your Photography<br/><em class="font-serif">Cheat Sheet</em>
        </h2>
        <p class="body-lg text-muted" style="margin-top: 1rem;">
          Scroll through these tips before your next celebration.
        </p>
      </div>

      <div class="carousel-wrapper" style="margin-top: var(--space-2xl);">
        <div class="carousel stagger-children">
          <div class="carousel-card">
            <span class="carousel-card__num">01</span>
            <h3 class="heading-md">Clean Your Lens</h3>
            <p class="body-md text-muted">A quick wipe on your shirt makes a huge difference. Smudges cause haze and ruin otherwise perfect shots.</p>
          </div>
          <div class="carousel-card">
            <span class="carousel-card__num">02</span>
            <h3 class="heading-md">Use Both Orientations</h3>
            <p class="body-md text-muted">Landscape for venues and groups, portrait for individuals. Mix it up to tell the complete visual story.</p>
          </div>
          <div class="carousel-card">
            <span class="carousel-card__num">03</span>
            <h3 class="heading-md">Get Close</h3>
            <p class="body-md text-muted">Don't rely on zoom — it degrades quality. Move physically closer to your subject for sharper, more intimate photos.</p>
          </div>
          <div class="carousel-card">
            <span class="carousel-card__num">04</span>
            <h3 class="heading-md">Shoot Burst Mode</h3>
            <p class="body-md text-muted">Hold the shutter button for action moments like dances, toasts, and cake cutting. Pick the best frame later.</p>
          </div>
          <div class="carousel-card">
            <span class="carousel-card__num">05</span>
            <h3 class="heading-md">Watch the Background</h3>
            <p class="body-md text-muted">A cluttered background distracts from the subject. Shift your angle slightly to find a cleaner backdrop.</p>
          </div>
          <div class="carousel-card">
            <span class="carousel-card__num">06</span>
            <h3 class="heading-md">Upload to Lumhe</h3>
            <p class="body-md text-muted">The best tip of all — share your photos to one permanent Lumhe Moments timeline so nothing gets lost.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section" style="padding-bottom: var(--space-3xl);">
    <div class="container">
      <div class="feat-cta reveal-scale">
        <h2 class="heading-xl" style="color: white;">
          Collect Every Memory<br/><em class="font-serif">From Your Event</em>
        </h2>
        <p class="body-lg" style="margin-top: 1rem; color: rgba(255,255,255,0.8); max-width: 480px; margin-left: auto; margin-right: auto;">
          Let every guest contribute their photos to one beautiful, permanent timeline. All free. Always.
        </p>
        <a href="#" class="btn btn-cta-white" style="margin-top: var(--space-lg);">
          Start Collecting Moments — Free <span class="arrow">&rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <Footer country={country} />
</Layout>

<style>
  @import '../../../styles/global.css';

  .feat-hero {
    min-height: 90vh;
    display: flex;
    align-items: center;
    padding: var(--space-3xl) 0;
    padding-top: calc(var(--space-3xl) + 80px);
    background: linear-gradient(180deg, var(--color-surface-warm) 0%, var(--color-surface) 60%);
  }

  .feat-hero__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-2xl);
    align-items: center;
  }

  .feat-hero__content { display: flex; flex-direction: column; gap: var(--space-md); }

  .feat-badge {
    font-family: var(--font-body); font-size: 0.7rem; font-weight: 700;
    letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-primary);
    background: rgba(255,82,82,0.06); padding: 0.4rem 1.2rem; border-radius: var(--radius-full);
    display: inline-block;
  }

  .feat-hero__content h1 { color: var(--color-charcoal); }
  .feat-hero__content h1 em { color: var(--color-primary); font-style: italic; }

  .feat-hero__cta { margin-top: var(--space-sm); }

  .feat-hero__img {
    width: 100%; max-width: 440px; border-radius: var(--radius-xl);
    box-shadow: var(--shadow-lg); margin: 0 auto; display: block;
  }

  /* ============================================
     EDITORIAL MAGAZINE LAYOUT
     ============================================ */
  .editorial {
    max-width: 860px;
    margin-left: auto;
    margin-right: auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  /* --- Pull-quote block --- */
  .editorial__block--pullquote {
    position: relative;
    padding: 3.5rem 3rem 3rem;
    text-align: center;
  }

  .editorial__quote-marks {
    font-family: var(--font-heading);
    font-size: 8rem;
    line-height: 0.6;
    color: var(--color-primary);
    opacity: 0.12;
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    pointer-events: none;
  }

  .editorial__block--pullquote h3 {
    color: var(--color-charcoal);
    margin-bottom: 0.75rem;
    position: relative;
  }

  .editorial__block--pullquote p {
    color: var(--color-charcoal);
    margin: 0 auto;
    font-style: italic;
    position: relative;
  }

  .editorial__tip-num {
    display: inline-block;
    margin-top: 1.5rem;
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-primary);
    border: 1px solid var(--color-primary);
    padding: 0.3rem 0.9rem;
    border-radius: var(--radius-full);
  }

  /* --- Two-column sidebar blocks --- */
  .editorial__split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .editorial__block--sidebar {
    display: flex;
    gap: 1.25rem;
    padding: 2rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    transition: transform 0.35s ease, box-shadow 0.35s ease;
  }

  .editorial__block--sidebar:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.06);
  }

  .editorial__sidebar-num {
    font-family: var(--font-heading);
    font-size: 3rem;
    font-weight: 800;
    color: var(--color-primary);
    opacity: 0.15;
    line-height: 1;
    flex-shrink: 0;
  }

  .editorial__sidebar-content h3 {
    margin-bottom: 0.5rem;
  }

  /* --- Blockquote with accent line --- */
  .editorial__block--blockquote {
    display: flex;
    gap: 0;
    padding: 2.5rem 0 2.5rem 0;
    margin-left: 3rem;
  }

  .editorial__accent-line {
    width: 4px;
    flex-shrink: 0;
    background: linear-gradient(180deg, var(--color-primary), var(--color-secondary));
    border-radius: 4px;
  }

  .editorial__blockquote-body {
    padding-left: 2rem;
  }

  .editorial__blockquote-num {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
  }

  .editorial__blockquote-body h3 {
    margin-bottom: 0.5rem;
  }

  /* --- Full-width banner --- */
  .editorial__block--banner {
    background: var(--color-charcoal);
    border-radius: var(--radius-xl);
    overflow: hidden;
  }

  .editorial__banner-inner {
    display: flex;
    align-items: center;
    gap: 2.5rem;
    padding: 3rem;
  }

  .editorial__banner-num {
    font-family: var(--font-heading);
    font-size: 5rem;
    font-weight: 800;
    color: var(--color-primary);
    line-height: 1;
    flex-shrink: 0;
    opacity: 0.7;
  }

  .editorial__banner-text h3 {
    color: white;
    margin-bottom: 0.5rem;
  }

  .editorial__banner-text p {
    color: rgba(255,255,255,0.7);
  }

  /* --- Marginal note style --- */
  .editorial__block--marginal {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 0;
    border-top: 1px solid var(--color-border);
    padding-top: 2.5rem;
  }

  .editorial__marginal-aside {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.15rem;
    padding-right: 2rem;
    border-right: 1px solid var(--color-border);
  }

  .editorial__marginal-label {
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .editorial__marginal-num {
    font-family: var(--font-heading);
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--color-primary);
    line-height: 1;
  }

  .editorial__marginal-body {
    padding-left: 2rem;
  }

  .editorial__marginal-body h3 {
    margin-bottom: 0.5rem;
  }

  /* ==========================================
     COMPARISON — WhatsApp vs Lumhe side-by-side
     ========================================== */
  .comparison {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 0;
    max-width: 900px;
    margin-left: auto;
    margin-right: auto;
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: 0 4px 24px rgba(0,0,0,0.08);
  }

  .comparison__side {
    padding: 2.5rem;
  }

  .comparison__side--whatsapp {
    background: #f3f4f6;
  }

  .comparison__side--lumhe {
    background: white;
    border: 2px solid var(--color-primary);
    border-left: none;
    border-radius: 0 var(--radius-xl) var(--radius-xl) 0;
    position: relative;
  }

  .comparison__header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-border);
  }

  .comparison__header--whatsapp h3 { color: var(--color-text-muted); }
  .comparison__header--lumhe h3 { color: var(--color-primary); }

  .comparison__icon { font-size: 1.5rem; }

  .comparison__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .comparison__item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-body);
    font-size: 1rem;
  }

  .comparison__item--negative { color: var(--color-text-muted); }
  .comparison__item--positive { color: var(--color-charcoal); font-weight: 500; }

  .comparison__mark {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  .comparison__mark--x {
    background: rgba(239, 68, 68, 0.1);
    color: #ef4444;
  }

  .comparison__mark--check {
    background: rgba(34, 197, 94, 0.1);
    color: #22c55e;
  }

  .comparison__divider {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 60px;
    background: linear-gradient(180deg, #f3f4f6, white);
    position: relative;
  }

  .comparison__vs {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 50%;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
  }

  /* ======================================
     TIPS CAROUSEL — Horizontal scroll cards
     ====================================== */
  .carousel-wrapper {
    overflow: hidden;
    margin-left: -1rem;
    margin-right: -1rem;
    padding: 0 1rem;
  }

  .carousel {
    display: flex;
    gap: 1.25rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding-bottom: 1.5rem;
    scrollbar-width: thin;
    scrollbar-color: var(--color-primary) transparent;
  }

  .carousel::-webkit-scrollbar { height: 4px; }
  .carousel::-webkit-scrollbar-track { background: transparent; }
  .carousel::-webkit-scrollbar-thumb { background: var(--color-primary); border-radius: 4px; }

  .carousel-card {
    flex: 0 0 260px;
    aspect-ratio: 3/4;
    scroll-snap-align: start;
    background: linear-gradient(160deg, white 0%, var(--color-surface-alt) 100%);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    position: relative;
    transition: transform 0.35s ease, box-shadow 0.35s ease;
  }

  .carousel-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 32px rgba(0,0,0,0.1);
  }

  .carousel-card__num {
    font-family: var(--font-heading);
    font-size: 4rem;
    font-weight: 700;
    color: rgba(255, 82, 82, 0.1);
    position: absolute;
    top: 1rem;
    left: 1.5rem;
    line-height: 1;
  }

  .carousel-card h3 {
    color: var(--color-charcoal);
    margin-bottom: 0.5rem;
  }

  /* CTA */
  .feat-cta {
    background: linear-gradient(135deg, var(--color-charcoal), var(--color-dark));
    border-radius: var(--radius-xl); padding: clamp(3rem, 6vw, 5rem); text-align: center;
    position: relative; overflow: hidden;
  }

  .btn-cta-white {
    background: white; color: var(--color-charcoal);
    padding: 1rem 2.5rem; border-radius: var(--radius-full);
    font-weight: 700; font-size: 1rem; text-decoration: none;
    display: inline-flex; align-items: center; gap: 0.5rem;
    transition: all 0.3s var(--ease-smooth); border: none; cursor: pointer;
  }
  .btn-cta-white:hover { transform: translateY(-2px); box-shadow: var(--shadow-lg); }
  .btn-cta-white .arrow { display: inline-block; transition: transform 0.3s var(--ease-smooth); }
  .btn-cta-white:hover .arrow { transform: translateX(4px); }

  /* ============ RESPONSIVE ============ */
  @media (max-width: 900px) {
    .feat-hero__inner { grid-template-columns: 1fr; text-align: center; }
    .feat-hero__content { align-items: center; }

    .editorial__split { grid-template-columns: 1fr; }
    .editorial__block--blockquote { margin-left: 0; }
    .editorial__block--marginal {
      grid-template-columns: 1fr;
    }
    .editorial__marginal-aside {
      flex-direction: row;
      align-items: center;
      gap: 0.5rem;
      border-right: none;
      border-bottom: 1px solid var(--color-border);
      padding-right: 0;
      padding-bottom: 1rem;
      margin-bottom: 1rem;
    }
    .editorial__marginal-body { padding-left: 0; }
    .editorial__banner-inner { flex-direction: column; text-align: center; gap: 1.5rem; }

    .comparison {
